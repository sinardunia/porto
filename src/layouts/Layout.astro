---
import Header from "../components/Header.astro";
import Footer from "@/components/Footer.astro";
import SEOTags from "@/components/seo/SEOTags.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";

import "@/styles/tailwind.css";

export interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  keywords?: string[];
  og?: {
    title?: string;
    description?: string;
    image?: string;
    alt?: string;
    type?: string;
    locale?: string;
  };
  jsonLd?: Record<string, any>;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const { title, description, noindex, keywords, og, jsonLd, article } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <SEOTags
      title={title}
      description={description}
      noindex={noindex}
      keywords={keywords}
      og={og}
      jsonLd={jsonLd}
      article={article}
    />
    <style is:inline>html{background:#fff}html.dark{background:#0a0a0a}</style>
    <script is:inline>(function(){const s=localStorage.getItem('theme')||'dark',p=matchMedia('(prefers-color-scheme:dark)').matches;if(s==='dark'||(!s&&p))document.documentElement.classList.add('dark')})()</script>
  </head>

  <body
    class="m-0 min-h-screen w-full bg-primary-light p-0 font-sans antialiased text-text-light dark:bg-neutral-950 dark:text-neutral-400"
  >
    <div class="mx-auto flex min-h-screen w-full max-w-[720px] flex-col gap-8 sm:gap-10 px-4 sm:px-6 py-6 sm:py-8 md:py-12">
      <Header />
      <main id="main-content" class="flex flex-1 flex-col min-w-0" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>

    <style is:global>
      html{font-family:system-ui,-apple-system,sans-serif;-webkit-font-smoothing:antialiased}
      .post{font-size:1.125rem;line-height:1.7}
      ::selection {
        background: rgba(120, 120, 120, 0.25);
      }
      html.dark ::selection {
        background: rgba(180, 180, 180, 0.25);
      }

      a[href]:not(.no-typewriter):not(.post a) {
        position: relative;
      }
      a[href]:not(.no-typewriter):not(.post a)::after {
        content: '|';
        position: absolute;
        right: -0.5em;
        opacity: 0;
        transition: opacity 0.15s ease;
        animation: none;
        font-weight: 300;
      }
      a[href]:not(.no-typewriter):not(.post a):hover::after {
        opacity: 1;
        animation: blink 1s step-end infinite;
      }
      @keyframes blink {
        50% { opacity: 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        a[href]:not(.no-typewriter):not(.post a)::after {
          display: none !important;
        }
      }
    </style>
    <script>document.addEventListener('keydown',function(e){if(e.key==='t'&&e.target instanceof HTMLElement&&!e.target.matches('input,textarea')){document.documentElement.classList.toggle('dark');localStorage.setItem('theme',document.documentElement.classList.contains('dark')?'dark':'light')}})</script>

    <ScrollToTop />


  </body>
</html>