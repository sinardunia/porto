---
import Header from "../components/Header.astro";
import Footer from "@/components/Footer.astro";
import SEOTags from "@/components/seo/SEOTags.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";
import Observability from "@/components/Observability.astro";

import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";

import "@/styles/tailwind.css";

export interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  keywords?: string[];
  og?: {
    title?: string;
    description?: string;
    image?: string;
    alt?: string;
    type?: string;
    locale?: string;
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
  tagNames?: string[];
}

const { title, description, noindex, keywords, og, jsonLd, article, tagNames = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <SEOTags
      title={title}
      description={description}
      noindex={noindex}
      keywords={keywords}
      og={og}
      jsonLd={jsonLd}
      article={article}
    />
    <style is:inline>
      html {
        background: #fafafa;
      }
      html.dark {
        background: #0a0a0a;
      }
    </style>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>

  <body
    class="relative m-0 min-h-screen w-full overflow-x-hidden bg-[#fafafa] p-0 font-sans antialiased text-neutral-800 dark:bg-[#0a0a0a] dark:text-neutral-400"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-neutral-900 focus:px-3 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>

    <div
      class="mx-auto flex min-h-screen w-full max-w-[800px] flex-col px-4 py-0"
    >
      <Header />
      <main id="main-content" class="flex flex-1 flex-col min-w-0 pt-5" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Mobile search overlay -->
    <div id="mobile-search-overlay" class="fixed inset-0 z-[60] hidden sm:hidden">
      <div class="fixed inset-0 bg-black/40 backdrop-blur-sm" data-close-mobile-search></div>
      <div class="fixed inset-x-0 top-0 z-10 border-b bg-white shadow-xl dark:border-neutral-700 dark:bg-neutral-900">
        <div class="mx-auto max-w-[800px] px-4 pb-4 pt-6">
          <form action="/" method="get" role="search">
            <div class="flex items-center border-b-2 border-neutral-300 pb-2">
              <svg class="h-5 w-5 shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="text"
                name="q"
                inputmode="search"
                enterkeyhint="search"
                placeholder="Cari tag atau artikel..."
                list="tag-suggestions"
                class="w-full bg-transparent pl-3 text-[15px] text-neutral-900 placeholder:text-neutral-400 focus:outline-none dark:text-neutral-100 dark:placeholder:text-neutral-500"
              />
              <datalist id="tag-suggestions">
                {tagNames.map(name => <option value={name} />)}
              </datalist>
              <input type="submit" hidden />
              <button type="button" class="ml-2 shrink-0 rounded-lg px-3 py-1.5 text-sm font-medium text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800" data-close-mobile-search>
                Batal
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <ScrollToTop />
    <Observability />
  </body>
</html>
