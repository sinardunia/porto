---
interface Props {
  value?: string;
  placeholder?: string;
  clearHref?: string;
  activeTag?: string;
}

const {
  value = "",
  placeholder = "Search articles...",
  clearHref = "/",
  activeTag = "",
} = Astro.props;

const hasQuery = value.length > 0;
---

<form
  action="/"
  method="get"
  role="search"
  class="w-full"
  data-search-form
  data-clear-href={clearHref}
  data-active-tag={activeTag}
>
  {activeTag && <input type="hidden" name="tag" value={activeTag} />}
  <label for="blog-search" class="sr-only">Search articles</label>
  <div class="relative">
    <span
      class="pointer-events-none absolute left-3.5 top-1/2 z-10 -translate-y-1/2 text-neutral-400 dark:text-neutral-500"
      aria-hidden="true"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </span>
    <input
      id="blog-search"
      type="text"
      name="q"
      value={value}
      inputmode="search"
      enterkeyhint="search"
      placeholder={placeholder}
      autocomplete="off"
      class="w-full rounded-lg border border-neutral-200 bg-white py-2.5 pl-10 pr-10 text-sm text-neutral-800 shadow-sm transition-colors placeholder:text-neutral-400 focus:border-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/10 dark:border-neutral-800 dark:bg-neutral-900/40 dark:text-neutral-100 dark:placeholder:text-neutral-600 dark:focus:border-neutral-600 dark:focus:ring-white/10"
    />
    <button
      type="button"
      data-search-clear
      hidden={!hasQuery}
      tabindex={hasQuery ? 0 : -1}
      aria-label="Clear search"
      class="absolute right-1.5 top-1/2 z-10 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md text-neutral-400 transition-colors hover:bg-neutral-100 hover:text-neutral-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-900/20 dark:hover:bg-neutral-800 dark:hover:text-neutral-200 dark:focus-visible:ring-white/20"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
</form>

<style>
  /* Prevent duplicate native clear control on some browsers */
  input[type="text"]::-webkit-search-cancel-button,
  input[type="text"]::-webkit-search-decoration {
    -webkit-appearance: none;
    appearance: none;
  }
</style>

<script>
  import "@/scripts/blog-search.ts";
</script>
