---
interface TagItem {
  name: string;
  slug: string;
  count: number;
}

interface Props {
  value?: string;
  placeholder?: string;
  clearHref?: string;
  activeTag?: string;
  tagData?: TagItem[];
}

const {
  value = "",
  placeholder = "Cari tag...",
  clearHref = "/",
  activeTag = "",
  tagData = [],
} = Astro.props;
---

<form
  action="/"
  method="get"
  role="search"
  class="w-full"
  data-search-form
  data-clear-href={clearHref}
  data-active-tag={activeTag}
>
  {activeTag && <input type="hidden" name="tag" value={activeTag} />}
  <label for="blog-search" class="sr-only">Cari tag atau artikel</label>
  <div class="relative">
    <div class="relative flex items-center border-b-2 border-neutral-300 transition-colors focus-within:border-neutral-900 dark:border-neutral-600 dark:focus-within:border-neutral-300">
      <span class="shrink-0 pb-2 text-neutral-400 dark:text-neutral-500" aria-hidden="true">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </span>
      <input
        id="blog-search"
        type="text"
        name="q"
        value={value}
        inputmode="search"
        enterkeyhint="search"
        placeholder={placeholder}
        autocomplete="off"
        class="w-full bg-transparent pb-2 pl-3 text-[15px] text-neutral-900 placeholder:text-neutral-400 focus:outline-none dark:text-neutral-100 dark:placeholder:text-neutral-500 sm:text-base"
      />
    </div>
    <ul
      id="tag-autocomplete"
      class="absolute left-0 right-0 z-50 mt-1 hidden rounded-lg border border-neutral-200 bg-white py-1 shadow-lg dark:border-neutral-700 dark:bg-neutral-900"
      role="listbox"
      aria-label="Saran tag"
    ></ul>
  </div>
</form>

<style>
  input[type="text"]::-webkit-search-cancel-button,
  input[type="text"]::-webkit-search-decoration {
    -webkit-appearance: none;
    appearance: none;
  }
</style>

<script>
  import "@/scripts/blog-search.ts";
</script>

<script define:vars={{ tagData }}>
  const input = document.getElementById("blog-search");
  const dropdown = document.getElementById("tag-autocomplete");
  if (!input || !dropdown) throw new Error("Missing search elements");

  let selectedIndex = -1;
  let currentResults: typeof tagData = [];

  function closeDropdown() {
    dropdown.classList.add("hidden");
    dropdown.innerHTML = "";
    selectedIndex = -1;
  }

  function openDropdown(results: typeof tagData) {
    currentResults = results;
    dropdown.innerHTML = results
      .map(
        (t, i) =>
          `<li role="option" aria-selected="false" data-index="${i}" data-slug="${t.slug}" class="flex cursor-pointer items-center justify-between px-4 py-2 text-sm text-neutral-700 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800">` +
          `<span>${t.name}</span>` +
          `<span class="tabular-nums text-neutral-400 dark:text-neutral-500">${t.count}</span>` +
          `</li>`
      )
      .join("");
    dropdown.classList.remove("hidden");
    selectedIndex = -1;
  }

  function selectTag(slug: string) {
    window.location.href = `/tags/${slug}`;
  }

  function highlightItem(index: number) {
    const items = dropdown.querySelectorAll<HTMLElement>("[role=option]");
    items.forEach((el, i) => {
      el.classList.toggle("bg-neutral-100", i === index);
      el.classList.toggle("dark:bg-neutral-800", i === index);
      el.setAttribute("aria-selected", i === index ? "true" : "false");
    });
  }

  input.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      closeDropdown();
      return;
    }
    const results = tagData.filter((t) => t.name.toLowerCase().includes(q)).slice(0, 6);
    if (results.length === 0) {
      closeDropdown();
      return;
    }
    openDropdown(results);
  });

  input.addEventListener("keydown", (e) => {
    if (!dropdown.classList.contains("hidden")) {
      const items = dropdown.querySelectorAll<HTMLElement>("[role=option]");
      if (e.key === "ArrowDown") {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
        highlightItem(selectedIndex);
        return;
      }
      if (e.key === "ArrowUp") {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, 0);
        highlightItem(selectedIndex);
        return;
      }
      if (e.key === "Enter" && selectedIndex >= 0) {
        e.preventDefault();
        const slug = currentResults[selectedIndex]?.slug;
        if (slug) selectTag(slug);
        return;
      }
      if (e.key === "Escape") {
        closeDropdown();
        return;
      }
    }
  });

  dropdown.addEventListener("click", (e) => {
    const li = (e.target as HTMLElement).closest<HTMLElement>("[data-slug]");
    if (!li) return;
    const slug = li.dataset.slug;
    if (slug) selectTag(slug);
  });

  document.addEventListener("click", (e) => {
    if (!input.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  input.addEventListener("blur", () => {
    setTimeout(closeDropdown, 200);
  });

  input.addEventListener("focus", () => {
    if (input.value.trim()) {
      input.dispatchEvent(new Event("input"));
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && !e.ctrlKey && !e.metaKey && !e.altKey) {
      const tag = (e.target as HTMLElement).tagName;
      if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return;
      e.preventDefault();
      input.focus();
    }
  });
</script>
