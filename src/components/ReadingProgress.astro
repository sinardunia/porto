<div id="reading-progress" class="fixed top-0 left-0 h-[2px] bg-neutral-800 dark:bg-neutral-200 z-[60] w-0"></div>

<script is:inline>
  (function() {
    const progressBar = document.getElementById('reading-progress');
    if (!progressBar) return;

    function calculateVisualProgress(real) {
      if (real <= 0.7) {
        return real * 100;
      } else if (real <= 0.9) {
        return 70 + (real - 0.7) * 75;
      } else {
        return 85 + (real - 0.9) * 150;
      }
    }

    function updateProgress() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const realProgress = docHeight > 0 ? scrollTop / docHeight : 0;
      const visualProgress = calculateVisualProgress(realProgress);
      progressBar.style.width = visualProgress + '%';
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(function() {
          updateProgress();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    updateProgress();
  })();
</script>
