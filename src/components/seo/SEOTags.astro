---
import { SEO } from "astro-seo";
import { SITE_URL } from "@/data/config";
import { AUTHOR } from "@/data/author";

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  keywords?: string[];
  og?: {
    title?: string;
    description?: string;
    image?: string;
    alt?: string;
    type?: string;
    locale?: string;
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
};

const { title, description, noindex, keywords, og, jsonLd, article } = Astro.props;

const SITE_NAME = "Artikel";
const AUTHOR_NAME = AUTHOR.name;
const AUTHOR_PSEUDONYM = AUTHOR.pseudonym;
const DEFAULT_DESCRIPTION = "Arsip pribadi yang tenang tentang pemikiran, tulisan, dan eksperimen.";
const DEFAULT_KEYWORDS = ["blog", "pribadi", "tulisan", "esai", "Waltahh"];

const pageTitle = title ? `${title} · ${SITE_NAME}` : SITE_NAME;
const pageDescription = description || DEFAULT_DESCRIPTION;
const pageKeywords = keywords ? [...DEFAULT_KEYWORDS, ...keywords] : DEFAULT_KEYWORDS;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImage = og?.image || new URL("/opengraph-image.png", SITE_URL).toString();
const locale = og?.locale || "id_ID";

const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdScript = jsonLdBlocks
  .map((block) => `<script type="application/ld+json">${JSON.stringify(block)}</script>`)
  .join("\n");
---

<SEO
  charset="UTF-8"
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  noindex={noindex || false}
  nofollow={noindex || false}
  openGraph={{
    basic: {
      title: og?.title || pageTitle,
      type: og?.type || "website",
      image: ogImage,
      url: canonicalUrl,
    },
    optional: {
      description: og?.description || pageDescription,
      locale,
      siteName: SITE_NAME,
    },
    image: {
      alt: og?.alt || `${SITE_NAME} — ${AUTHOR_NAME}`,
      width: 1200,
      height: 630,
    },
    article: article
      ? {
          publishedTime: article.publishedTime,
          modifiedTime: article.modifiedTime,
          authors: article.author ? [article.author] : undefined,
          tags: article.tags,
        }
      : undefined,
  }}
  twitter={{
    card: "summary_large_image",
    creator: "@fuhara16",
    site: "@fuhara16",
    title: og?.title || pageTitle,
    description: og?.description || pageDescription,
    image: ogImage,
    imageAlt: og?.alt || `${SITE_NAME} — ${AUTHOR_NAME}`,
  }}
  extend={{
    link: [
      { rel: "icon", href: "/favicon.ico", sizes: "any" },
      { rel: "icon", href: "/favicon-32.png", type: "image/png", sizes: "32x32" },
      { rel: "icon", href: "/favicon-16.png", type: "image/png", sizes: "16x16" },
      { rel: "apple-touch-icon", href: "/apple-touch-icon.png" },
      { rel: "manifest", href: "/site.webmanifest" },
      { rel: "canonical", href: canonicalUrl },
      { rel: "alternate", type: "application/rss+xml", title: "RSS Feed", href: "/rss.xml" },
      { rel: "sitemap", type: "application/xml", href: "/sitemap.xml" },
    ],
    meta: [
      { name: "google-site-verification", content: "i3B2Tnl4moZ7uUvKo_gisVVg2CcEFh4YPtneljzuB6A" },
      { name: "viewport", content: "width=device-width, initial-scale=1, viewport-fit=cover" },
      { name: "theme-color", content: "#0a0a0a", media: "(prefers-color-scheme: dark)" },
      { name: "theme-color", content: "#ffffff", media: "(prefers-color-scheme: light)" },
      { name: "author", content: AUTHOR_NAME },
      { name: "creator", content: AUTHOR_PSEUDONYM },
      { name: "copyright", content: `2024–Present ${AUTHOR_PSEUDONYM}` },
      { name: "keywords", content: pageKeywords.join(", ") },
      { name: "language", content: "id" },
      {
        name: "robots",
        content: noindex
          ? "noindex, nofollow"
          : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1",
      },
      { name: "color-scheme", content: "dark light" },
      { name: "format-detection", content: "telephone=no" },
    ],
  }}
/>

<Fragment set:html={jsonLdScript} />
