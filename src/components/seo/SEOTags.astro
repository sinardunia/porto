---
import { SEO } from "astro-seo";
import { SITE_URL } from "@/data/config";

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  keywords?: string[];
  og?: {
    title?: string;
    description?: string;
    image?: string;
    alt?: string;
    type?: string;
    locale?: string;
  };
  jsonLd?: Record<string, any>;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
};

const {
  title,
  description,
  noindex,
  keywords,
  og,
  jsonLd,
  article,
} = Astro.props;

const DEFAULT_TITLE = "Fuji Halim Rabani";
const DEFAULT_DESCRIPTION = "A quiet personal archive of thoughts, writing, and experiments.";
const DEFAULT_KEYWORDS = ["blog", "personal", "writing", "essays", "thoughts"];

const pageTitle = title ? `${title} • Fuji` : DEFAULT_TITLE;
const pageDescription = description || DEFAULT_DESCRIPTION;
const pageKeywords = keywords ? [...DEFAULT_KEYWORDS, ...keywords] : DEFAULT_KEYWORDS;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImage = og?.image || `${SITE_URL.replace(/\/$/, "")}/opengraph-image.jpg`;
const locale = og?.locale || "id_ID";

const jsonLdScript = jsonLd
  ? `<script type="application/ld+json">${JSON.stringify(jsonLd)}</script>`
  : "";
---

<SEO
  charset="UTF-8"
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  noindex={noindex || false}
  nofollow={noindex || false}
  openGraph={{
    basic: {
      title: og?.title || pageTitle,
      type: og?.type || "website",
      image: ogImage,
      url: canonicalUrl,
    },
    optional: {
      description: og?.description || pageDescription,
      locale: locale,
      siteName: "Fuji Halim Rabani",
    },
    image: {
      alt: og?.alt || "Fuji Halim Rabani personal website",
      width: 1200,
      height: 630,
    },
    article: article ? {
      publishedTime: article.publishedTime,
      modifiedTime: article.modifiedTime,
      authors: article.author ? [article.author] : undefined,
      tags: article.tags,
    } : undefined,
  }}
  twitter={{
    card: "summary_large_image",
    creator: "@fuhara16",
    site: "@fuhara16",
    title: og?.title || pageTitle,
    description: og?.description || pageDescription,
    image: ogImage,
    imageAlt: og?.alt || "Fuji Halim Rabani personal website",
  }}
  extend={{
    link: [
      { rel: "icon", href: "/favicon.ico" },
      { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
      { rel: "apple-touch-icon", href: "/apple-touch-icon.png" },
      { rel: "manifest", href: "/manifest.json" },
      { rel: "canonical", href: canonicalUrl },
      { rel: "alternate", type: "application/rss+xml", title: "RSS Feed", href: "/rss.xml" },
      { rel: "sitemap", type: "application/xml", href: "/sitemap.xml" },
      { rel: "alternate", hreflang: "id", href: canonicalUrl },
      { rel: "alternate", hreflang: "x-default", href: canonicalUrl },
    ],
    meta: [
      { name: "viewport", content: "width=device-width, initial-scale=1, viewport-fit=cover" },
      { name: "theme-color", content: "#0a0a0a", media: "(prefers-color-scheme: dark)" },
      { name: "theme-color", content: "#ffffff", media: "(prefers-color-scheme: light)" },
      { name: "generator", content: Astro.generator },
      { name: "author", content: "Fuji Halim Rabani" },
      { name: "keywords", content: pageKeywords.join(", ") },
      { name: "language", content: "id" },
      { name: "geo.country", content: "id" },
      { name: "geo.placename", content: "Indonesia" },
      { name: "robots", content: noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" },
      { name: "googlebot", content: noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" },
      { name: "bingbot", content: noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" },
      { name: "referrer", content: "strict-origin-when-cross-origin" },
      { name: "color-scheme", content: "dark light" },
      { name: "format-detection", content: "telephone=no" },
      { name: "copyright", content: "Fuji Halim Rabani" },
      { name: "owner", content: "Fuji Halim Rabani" },
      { name: "dc.title", content: pageTitle },
      { name: "dc.description", content: pageDescription },
      { name: "dc.creator", content: "Fuji Halim Rabani" },
      { name: "dc.language", content: "id" },
      { name: "dc.publisher", content: SITE_URL },
    ],
  }}
/>

<Fragment set:html={jsonLdScript} />