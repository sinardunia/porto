<style>
  .ascii-badge {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    font-family: "SF Mono", "Monaco", "Consolas", monospace;
    font-size: 0.75rem;
    line-height: 1;
    vertical-align: middle;
    margin: 0 0.25rem;
    opacity: 0.6;
    transition: opacity 0.2s ease;
    cursor: default;
  }
  
  .ascii-badge:hover {
    opacity: 0.9;
  }
  
  .ascii-dot {
    display: inline-block;
    background: linear-gradient(135deg, #78716c 0%, #57534e 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  
  .ascii-badge:hover .ascii-dot {
    opacity: 0.9;
  }
  
  :global(.dark) .ascii-dot {
    background: linear-gradient(135deg, #a8a29e 0%, #78716c 100%);
    -webkit-background-clip: text;
    background-clip: text;
    opacity: 0.85;
  }
  
  :global(.dark) .ascii-badge:hover .ascii-dot {
    opacity: 1;
  }
  
  @media (min-width: 768px) {
    .ascii-badge {
      font-size: 0.875rem;
    }
  }
  
  .ascii-terminal {
    display: none;
  }
  
  @media (min-width: 1024px) {
    .ascii-terminal {
      display: block;
      font-family: "SF Mono", "Monaco", "Consolas", monospace;
      width: 260px;
      flex-shrink: 0;
      opacity: 0.6;
      transition: opacity 0.3s ease;
      margin-top: -20px;
      
      border: 1px solid #737373;
      background: #fafafa;
      padding: 18px;
    }
    
    :global(.dark) .ascii-terminal {
      border-color: #262626;
      background: #0a0a0a;
    }
    
    .ascii-terminal:hover {
      opacity: 0.85;
    }
    
    .terminal-content {
      margin: 0;
      font-size: 0.65rem;
      line-height: 1.1;
      white-space: pre;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      background: linear-gradient(
        180deg,
        #22c55e 0%,
        #16a34a 15%,
        #15803d 35%,
        #166534 50%,
        #15803d 65%,
        #16a34a 85%,
        #22c55e 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    
    .terminal-content::-webkit-scrollbar {
      display: none;
    }
    
    :global(.dark) .terminal-content {
      background: linear-gradient(
        180deg,
        #86efac 0%,
        #4ade80 20%,
        #22c55e 40%,
        #16a34a 50%,
        #22c55e 60%,
        #4ade80 80%,
        #86efac 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      filter: drop-shadow(0 0 3px rgba(74, 222, 128, 0.5));
    }
  }
</style>


