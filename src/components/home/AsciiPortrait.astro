---
// ASCII portrait - two modes:
// - inline: minimal badge for heading
// - side: terminal window beside intro text (desktop only)
interface Props {
  variant?: "inline" | "side";
}

const { variant = "inline" } = Astro.props;
---

{variant === "inline" ? (
  <span class="ascii-badge" aria-hidden="true" title="ASCII portrait">
    <span class="ascii-dot">в ҝ</span>
    <span class="ascii-dot">в ҝ</span>
  </span>
) : (
  <div class="ascii-terminal" aria-hidden="true">
    <pre class="terminal-content">вўёвЈҮвў№вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвўҝвЎҹвЈҝвЈ»вўҝвЈҝвЎ·вўүвЈҫвЈҝвЈ®вЎҷвЈҝвЈҝвЈҝвЎҝвЈҝвЈ·вЎҲ
в ёвЈҝвЎҶвў»вЈҝвЈҝвЎҝвЈҸвў»вЈҹвЎҫвЈҪвЈівЈҜвЈҝвЈҘв °вЈҮвЈҝвЈҝвЈҝв ҹвЈ¬вўівЈҝвЈ·вў№вЈҝвЈ§
вЎҮвЈҝвЈҝвЈҶвў»вЈҝвЎҪвЈ»вЈҶв №вЈҝвЈҪвЈҝвЈҪвЈ·вЈҝвўҶвЈҝв ңв ӣв Ӣв Ҳв ӣв ғв ҷвЈәв јвЈ·вўҝ
вЈ·вўЁвЈӯвЈӯвЈҘвЎЎвЈ¶вЈҹвЈҫвЈ°вЎ№вЈҝвЈҝвЈҝвЈҝвЈҝвўҫв ҒвЈ вЈ¶в ҫв ҝвў·вЈ¶вЈ„в Ҳвў«вЈҹвЈҝ
вўҝвЎҶвЈҝвЈҝвЈҝвЈ·вЎқвЈҝвЈҝвЈ§вЈ—вЈҝвЎҝвЈҹвЈҝвЈҫвЎҮвЈёвЎҹвЈЎвЎҗвЎІвўҰвЎҢвў»вЈ·вЎҖвўёвЈҝ
вЈҝвЈҝвЎңв ҳв ӣв ӣв ӣв ӢвўҪвЈ·вЈҝвЈҜвЈҝвЈҝвЈҝвЈҝвЈ·вЈҝвЎҮвЈҝв ·вЈ»вЈҰвЎӯвўӮвўҝвЈҮв ҲвЈҝ
вЈҝв Ҡв ҖвЈ вЈӨвЎ¶в ¶вЈӨвЈӨвЈ№вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҖвЎңвЈ©вўҝвЈ¶вЎҹвЈёвЈҝвЈҶвЎү
в Үв ҖвЈјвЈҝвўҒв °в °вЈӨвўҚвў»вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЎңв Ҝвўҝв »вўғвЈҹвў¬вЈӯвЈ¶
в „вўёвЈҝвЎ§вЈҝвЈ·вў»вЈӨвЎҜвўҶвў№вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ¶вЈҝвЈҝвЈҸвЈҡвЈівЈө
в ҖвўёвЈҝвЈҝвЎҲв Өв ҝвЈ»вЈ§вЈҝв ҶвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝ
вЈҰв  вЈ»вЈҝвЈ·вЈҢв №вЈҜвўҝвЎҹвўЈвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвўӣв ҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝ
вЈҝвЈ§вЎҷвЈҝвЈҝвЎҝвў·вў¶вЈ¶вЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҜвўёвЈівЎңвўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Ү
вЈҝвЎӣвЈҝвўҰвЎ№вЈ“вЈҜвЈӯвЎқвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎ”вў§вЈӣвЈёвЈҝвЈҝвЈҝвЈҝвЎҝв ғвЈ 
вЈҫвЎҪвЎҶвўҝв јвЎ»в һвЈЈвЈјвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈ¶вЈҝвЈҝвЈҝвЈҝв ҝв Ӣв ҖвЈҲв Ғ
вЈҝвЈҪвЈ·в Җв “в ·в ҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв ҹв ӢвЈЎв ҙвў®вЎҪвЎ№вў§</pre>
  </div>
)}

<style>
  /* Inline badge styles */
  .ascii-badge {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    font-family: "SF Mono", "Monaco", "Consolas", monospace;
    font-size: 0.75rem;
    line-height: 1;
    vertical-align: middle;
    margin: 0 0.25rem;
    opacity: 0.6;
    transition: opacity 0.2s ease;
    cursor: default;
  }
  
  .ascii-badge:hover {
    opacity: 0.9;
  }
  
  .ascii-dot {
    display: inline-block;
    /* Light mode: stone/warm gray вҖ” calm, beda dari terminal */
    background: linear-gradient(135deg, #78716c 0%, #57534e 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  
  .ascii-badge:hover .ascii-dot {
    opacity: 0.9;
  }
  
  :global(.dark) .ascii-dot {
    /* Dark mode: warm stone */
    background: linear-gradient(135deg, #a8a29e 0%, #78716c 100%);
    -webkit-background-clip: text;
    background-clip: text;
    opacity: 0.85;
  }
  
  :global(.dark) .ascii-badge:hover .ascii-dot {
    opacity: 1;
  }
  
  @media (min-width: 768px) {
    .ascii-badge {
      font-size: 0.875rem;
    }
  }
  
  /* Desktop terminal - Arch aesthetic: clean, minimal, no bullshit */
  .ascii-terminal {
    display: none;
  }
  
  @media (min-width: 1024px) {
    .ascii-terminal {
      display: block;
      font-family: "SF Mono", "Monaco", "Consolas", monospace;
      width: 260px;
      flex-shrink: 0;
      opacity: 0.6;
      transition: opacity 0.3s ease;
      margin-top: -20px;
      
      /* Arch terminal: single border, no radius, clean */
      border: 1px solid #737373;
      background: #fafafa;
      padding: 18px;
    }
    
    :global(.dark) .ascii-terminal {
      border-color: #262626;
      background: #0a0a0a;
    }
    
    .ascii-terminal:hover {
      opacity: 0.85;
    }
    
    .terminal-content {
      margin: 0;
      font-size: 0.65rem;
      line-height: 1.1;
      white-space: pre;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      
      /* Light mode: tema emerald gradient */
      background: linear-gradient(
        180deg,
        #22c55e 0%,
        #16a34a 15%,
        #15803d 35%,
        #166534 50%,
        #15803d 65%,
        #16a34a 85%,
        #22c55e 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    
    .terminal-content::-webkit-scrollbar {
      display: none;
    }
    
    :global(.dark) .terminal-content {
      /* Dark mode: bright lime glow вҖ” matrix vibes */
      background: linear-gradient(
        180deg,
        #86efac 0%,
        #4ade80 20%,
        #22c55e 40%,
        #16a34a 50%,
        #22c55e 60%,
        #4ade80 80%,
        #86efac 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      filter: drop-shadow(0 0 3px rgba(74, 222, 128, 0.5));
    }
  }
</style>


