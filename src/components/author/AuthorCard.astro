---
import AuthorAvatar from "./AuthorAvatar.astro";
import { AUTHOR } from "@/data/author";

interface Props {
  variant?: "compact" | "full";
  showAvatar?: boolean;
}

const { variant = "compact", showAvatar = true } = Astro.props;
---

<div
  class:list={[
    "flex gap-3",
    variant === "full" ? "flex-col sm:flex-row sm:items-start sm:gap-5" : "items-center",
  ]}
>
  {showAvatar && <AuthorAvatar size={variant === "full" ? "lg" : "sm"} />}
  <div class="min-w-0">
    <p class="text-sm font-medium text-neutral-800 dark:text-neutral-200">{AUTHOR.name}</p>
    <p
      class:list={[
        "text-neutral-500 dark:text-neutral-500",
        variant === "full" ? "mt-2 text-sm leading-relaxed" : "mt-0.5 text-xs leading-relaxed",
      ]}
    >
      {variant === "full" ? AUTHOR.bioLong : AUTHOR.bio}
    </p>
    {variant === "full" && (
      <a
        href={AUTHOR.url}
        class="mt-3 inline-flex min-h-[44px] items-center text-sm text-neutral-600 underline-offset-2 hover:underline dark:text-neutral-400"
        rel="noopener noreferrer"
        target="_blank"
      >
        {AUTHOR.handle}
      </a>
    )}
  </div>
</div>
