---
import { Image } from "astro:assets";
import mascot from "@/assets/author-mascot.png";

interface Props {
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { size = "md", class: className = "" } = Astro.props;

const px = size === "sm" ? 40 : size === "lg" ? 96 : 56;
const ring =
  size === "sm"
    ? "ring-1 ring-neutral-200/80 dark:ring-neutral-700/80"
    : "ring-1 ring-neutral-200/70 dark:ring-neutral-700/70";
---

<div
  class:list={[
    "relative shrink-0 overflow-hidden rounded-full bg-neutral-100 dark:bg-neutral-900",
    ring,
    className,
  ]}
  style={`width: ${px}px; height: ${px}px;`}
>
  <Image
    src={mascot}
    alt=""
    width={px}
    height={px}
    widths={[px, px * 2]}
    sizes={`${px}px`}
    class="h-full w-full object-cover object-[center_18%] scale-[1.35]"
    loading="lazy"
    decoding="async"
  />
</div>
