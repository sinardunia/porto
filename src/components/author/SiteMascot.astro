---
import { Image } from "astro:assets";
import mascot from "@/assets/author-mascot.png";

interface Props {
  variant?: "inline" | "hero";
  class?: string;
}

const { variant = "inline", class: className = "" } = Astro.props;

const dimensions =
  variant === "hero"
    ? { width: 200, height: 280, widths: [120, 160, 200, 280] as number[], sizes: "(max-width: 640px) 120px, 200px" }
    : { width: 88, height: 120, widths: [88, 120, 176] as number[], sizes: "88px" };
---

<figure
  class:list={[
    "pointer-events-none select-none",
    variant === "hero" ? "mx-auto" : "hidden sm:block",
    className,
  ]}
  aria-hidden="true"
>
  <Image
    src={mascot}
    alt=""
    width={dimensions.width}
    height={dimensions.height}
    widths={dimensions.widths}
    sizes={dimensions.sizes}
    class:list={[
      "h-auto w-auto object-contain opacity-[0.42] dark:opacity-[0.32]",
      variant === "hero" ? "max-h-[280px]" : "max-h-[120px]",
    ]}
    loading="lazy"
    decoding="async"
  />
</figure>
