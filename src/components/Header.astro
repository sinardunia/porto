---
import removeTrailingSlash from "@/utils/removeTrailingSlash";
import DarkModeToggle from "./DarkModeToggle.astro";

const pathname = removeTrailingSlash(Astro.url.pathname);
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent">
  <div class="max-w-[872px] mx-auto px-6 md:px-10 py-3.5 md:py-5">
    <div class="flex items-center justify-between w-full min-w-0">
      
      <a href="/" class="flex items-center active:scale-95 transition-transform duration-200 flex-shrink-0" title="Home">
        <div class="w-8 h-8 rounded-full overflow-hidden border border-neutral-200/50 dark:border-neutral-800/60 shadow-sm transition-opacity opacity-90 hover:opacity-100">
          <img 
            src="/pfp.jpeg" 
            alt="Fuji" 
            class="w-full h-full object-cover"
          />
        </div>
      </a>

      <nav class="flex items-center gap-4 md:gap-7 min-w-0">
        <ul class="flex items-center gap-1 md:gap-8 text-xs font-medium tracking-wide text-neutral-500 dark:text-neutral-400">
          
          <li>
            <a href="/posts" class:list={[
              "py-2 px-3 md:p-0 flex items-center justify-center transition-all duration-200 relative",
              pathname === "/posts" 
                ? "text-neutral-900 dark:text-white font-semibold" 
                : "hover:text-neutral-900 dark:hover:text-neutral-200"
            ]} title="Blog">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="md:hidden" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
              </svg>
              <span class="hidden md:block">Blog</span>
            </a>
          </li>

          <li>
            <a href="/thoughts" class:list={[
              "py-2 px-3 md:p-0 flex items-center justify-center transition-all duration-200 relative",
              pathname === "/thoughts" 
                ? "text-neutral-900 dark:text-white font-semibold" 
                : "hover:text-neutral-900 dark:hover:text-neutral-200"
            ]} title="Thoughts">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="md:hidden" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 20h9"></path>
                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
              </svg>
              <span class="hidden md:block">Thoughts</span>
            </a>
          </li>

          <li>
            <a href="/chatango" class:list={[
              "py-2 px-3 md:p-0 flex items-center justify-center transition-all duration-200 relative",
              pathname === "/chatango" 
                ? "text-neutral-900 dark:text-white font-semibold" 
                : "hover:text-neutral-900 dark:hover:text-neutral-200"
            ]} title="Chat">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="md:hidden" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              <span class="hidden md:block">Chat</span>
            </a>
          </li>
        </ul>
        
        <div class="pl-3 md:pl-5 border-l border-neutral-200/60 dark:border-neutral-800/50 flex items-center h-4 flex-shrink-0">
          <DarkModeToggle />
        </div>
      </nav>
      
    </div>
  </div>
</header>

<div class="h-16 md:h-20 w-full block"></div>

<style>
  header { 
    -webkit-tap-highlight-color: transparent;
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('main-header');
    let lastScroll = 0;

    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll);

    function handleScroll() {
      const currentScroll = window.scrollY;

      // Efek Blur Kaca Pudar yang Halus
      if (currentScroll > 10) {
        header?.classList.add(
          'bg-white/80', 
          'dark:bg-[#0a0a0a]/80', 
          'backdrop-blur-md', 
          'border-neutral-200/20', 
          'dark:border-neutral-900/30 shadow-sm'
        );
      } else {
        header?.classList.remove(
          'bg-white/80', 
          'dark:bg-[#0a0a0a]/80', 
          'backdrop-blur-md', 
          'border-neutral-200/20', 
          'dark:border-neutral-900/30 shadow-sm'
        );
      }

      // Hide on Scroll Down, Show on Scroll Up
      if (currentScroll > lastScroll && currentScroll > 100) {
        if (header) header.style.transform = 'translateY(-100%)';
      } else {
        if (header) header.style.transform = 'translateY(0)';
      }
      lastScroll = currentScroll;
    }
  }

  // Eksekusi aman untuk siklus hidup normal maupun sistem View Transitions Astro
  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>