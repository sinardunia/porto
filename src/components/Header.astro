---
import DarkModeToggle from "./DarkModeToggle.astro";
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 border-b border-neutral-200/60 bg-white/85 backdrop-blur-md dark:border-neutral-800/60 dark:bg-[#0a0a0a]/85"
>
  <div class="mx-auto flex h-14 max-w-[720px] items-center justify-between gap-4 px-4 sm:h-16 sm:px-6">
    <a
      href="/"
      class="no-typewriter truncate text-[15px] font-semibold tracking-tight text-neutral-900 transition-colors hover:text-neutral-600 dark:text-neutral-100 dark:hover:text-neutral-300 sm:text-base"
    >
      Blogs.
    </a>

    <DarkModeToggle />
  </div>
</header>

<div class="h-14 w-full sm:h-16" aria-hidden="true"></div>
