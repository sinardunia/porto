---
type Props = {
  thoughtId: string;
  content?: string;
};

const { thoughtId, content } = Astro.props;

const isLongText = content && content.length > 500;
---

{
  content && (
    <div class="w-full px-1">

      <div
        class:list={[
          "relative overflow-hidden transition-all duration-300",
          isLongText ? "max-h-[320px] pb-12" : "",
        ]}
        id={`content-${thoughtId}`}
      >

        <p class="whitespace-pre-wrap break-words text-[14px] leading-[1.7] text-neutral-800 dark:text-neutral-200">
          {content}
        </p>

        {
          isLongText && (
            <div class="absolute bottom-0 left-0 flex h-24 w-full items-end justify-center bg-gradient-to-t from-white to-transparent dark:from-[#0a0a0a]">
              <button
                class="read-more-btn pb-2 text-[10px] font-bold uppercase tracking-widest text-neutral-400 transition-colors hover:text-orange-500"
                data-id={thoughtId}
              >
                baca selengkapnya
              </button>
            </div>
          )
        }

      </div>

    </div>
  )
}

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;

    const btn = target.closest<HTMLElement>('.read-more-btn');
    if (!btn) return;

    const id = btn.getAttribute('data-id');
    if (!id) return;

    const contentDiv = document.getElementById(`content-${id}`);
    if (!contentDiv) return;

    // Expand: remove max-height and padding constraint
    contentDiv.classList.remove('max-h-[320px]', 'pb-12');

    // Hide gradient + button
    const overlay = contentDiv.querySelector('.absolute.bottom-0');
    if (overlay) overlay.remove();
  });
</script>