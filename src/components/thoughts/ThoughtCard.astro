---
import type { Thought } from "@/types/thoughts";

type Props = {
  thought: Thought;
};

const { thought } = Astro.props;
const images = thought.thought_images?.length
  ? thought.thought_images
  : thought.image_url
    ? [{ id: thought.id, image_url: thought.image_url, image_alt: thought.image_alt, position: 0 }]
    : [];
const createdAt = new Date(thought.created_at);
const formattedDate = Number.isNaN(createdAt.getTime()) ? thought.created_at : [
  new Intl.DateTimeFormat("en-US", {
    hour: "numeric",
    minute: "2-digit",
  }).format(createdAt),
  new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(createdAt),
].join(" · ");
---

<article class="group relative pb-10">
  <div class="absolute bottom-0 left-0 h-px w-16 bg-border-light/70 dark:bg-neutral-800/80"></div>

  <p class="whitespace-pre-wrap text-[1rem] leading-8 text-neutral-800 dark:text-neutral-200 md:text-[1.03rem]">
    {thought.content}
  </p>

  {images.length > 0 && (
    <div class:list={[
      "mt-5 grid gap-2",
      images.length === 1 ? "grid-cols-1" : "grid-cols-2",
      images.length >= 3 ? "sm:grid-cols-3" : "",
    ]}>
      {images.map((image) => (
        <button type="button" class="thought-image-button rounded-xl text-left focus:outline-none focus:ring-2 focus:ring-neutral-300" data-image-url={image.image_url} data-image-alt={image.image_alt || ""}>
          <img
            src={image.image_url}
            alt={image.image_alt || ""}
            loading="lazy"
            decoding="async"
            sizes={images.length === 1 ? "(min-width: 768px) 672px, 100vw" : "(min-width: 768px) 320px, 50vw"}
            class:list={[
              "h-auto w-full rounded-xl object-contain opacity-95",
              images.length === 1 ? "max-h-[560px]" : "max-h-[340px]",
            ]}
          />
        </button>
      ))}
    </div>
  )}

  <time
    datetime={thought.created_at}
    class="mt-4 block text-[0.72rem] tracking-wide text-neutral-400 dark:text-neutral-600"
  >
    {formattedDate}
  </time>
</article>
