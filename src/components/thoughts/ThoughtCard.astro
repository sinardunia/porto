---
import type { Thought, ThoughtMedia } from "@/types/thoughts";

import ThoughtHeader from "./ThoughtHeader.astro";
import ThoughtContent from "./ThoughtContent.astro";
import ThoughtMediaCarousel from "./ThoughtMediaCarousel.astro";

type Props = {
  thought: Thought;
};

const { thought } = Astro.props;

const media: ThoughtMedia[] = thought.thought_media || [];

function humanizeTime(date: Date) {
  const now = new Date();
  const diffInSeconds = Math.floor((now.getTime() - date.getTime()) / 1000);

  if (diffInSeconds < 60) return "Baru saja";

  const diffInMinutes = Math.floor(diffInSeconds / 60);

  if (diffInMinutes < 60) {
    return `${diffInMinutes} menit yang lalu`;
  }

  const diffInHours = Math.floor(diffInMinutes / 60);

  if (diffInHours < 24) {
    if (now.getDate() === date.getDate()) {
      return `Hari ini, ${date.toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      })}`;
    }
  }

  const yesterday = new Date(now);

  yesterday.setDate(now.getDate() - 1);

  if (
    yesterday.getDate() === date.getDate() &&
    yesterday.getMonth() === date.getMonth() &&
    yesterday.getFullYear() === date.getFullYear()
  ) {
    return `Kemarin, ${date.toLocaleTimeString([], {
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    })}`;
  }

  return date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "short",
  });
}

const displayTime = humanizeTime(new Date(thought.created_at));
---

<article
  class="w-full max-w-[500px] mx-auto mb-10 border-b border-neutral-100/70 pb-10 last:border-0 last:pb-0 dark:border-neutral-900/40"
>
  <div class="flex flex-col gap-3.5">

    <ThoughtHeader time={displayTime} />

    <ThoughtContent
      thoughtId={thought.id}
      content={thought.content}
    />

    {media.length > 0 && (
      <ThoughtMediaCarousel media={media} />
    )}

  </div>
</article>

<style>
  article {
    -webkit-tap-highlight-color: transparent;
  }
</style>