---

interface Props {
  src: string;
  isSingleMedia?: boolean; 
}
const { src, isSingleMedia } = Astro.props;
---

<neuro-stream
  class:list={[
    "relative block w-full bg-black snap-start overflow-hidden select-none",
    isSingleMedia ? "h-[100dvh]" : "h-full"
  ]}
  data-src={src}
>
  <div class="video-skeleton absolute inset-0 bg-neutral-900 animate-pulse"></div>

  <video
    class="video-el h-full w-full object-contain opacity-0 transition-opacity duration-700 ease-out"
    loop
    playsinline
    disablepictureinpicture
    disableRemotePlayback
    preload="metadata"
  ></video>

  <!-- LAYER INTERAKSI -->
  <div class="interaction-layer absolute inset-0 z-10 flex items-center justify-center pointer-events-auto">
    <div class="state-icon pointer-events-none opacity-0 scale-50 transition-all duration-300 bg-black/40 p-6 rounded-full backdrop-blur-md border border-white/10">
       <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </div>
  </div>

  <!-- AUDIO CONTROL -->
  <div class="absolute bottom-24 right-4 z-30 flex flex-col items-center gap-3">
    <button class="audio-toggle p-4 rounded-full bg-red-600 shadow-[0_0_30px_rgba(255,0,0,0.4)] active:scale-90 transition-all border-2 border-white/20">
      <div class="icon-container text-white flex items-center justify-center"></div>
    </button>
    <div class="audio-hint-box opacity-0 transition-opacity duration-500">
        <span class="text-[10px] font-black text-white uppercase bg-red-600 px-2 py-1 rounded-sm shadow-lg animate-bounce">
          Tap Sound
        </span>
    </div>
  </div>

  <!-- SCRUBBER -->
  <div class="scrub-container absolute bottom-0 left-0 w-full h-16 z-30 flex items-end cursor-pointer group">
    <div class="h-[4px] w-full bg-white/10 group-hover:h-[6px] transition-all relative">
      <div class="progress-bar h-full bg-[#FF0000] w-0 shadow-[0_0_20px_rgba(255,0,0,0.8)] relative">
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-4 h-4 bg-[#FF0000] rounded-full scale-0 group-hover:scale-100 transition-transform shadow-[0_0_15px_rgba(255,0,0,1)]"></div>
      </div>
    </div>
  </div>
</neuro-stream>

<script>
  // STATE MANAGEMENT
  const GlobalState = {
    isMuted: true,
    activeInstance: null as any,
    subscribers: new Set<any>(),
    toggleAudio() {
      this.isMuted = !this.isMuted;
      this.subscribers.forEach(s => s.syncAudio());
    }
  };

  // SINGLETON OBSERVER (Hemat Resource)
  const sharedObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const target = entry.target as any;
      if (entry.isIntersecting) target.playInstance();
      else target.pauseInstance();
    });
  }, { threshold: 0.6 });

  class NeuroStream extends HTMLElement {
    public video!: HTMLVideoElement;
    private progress!: HTMLElement;
    private skeleton!: HTMLElement;
    private audioBtn!: HTMLButtonElement;
    private interactionLayer: HTMLElement | null = null;
    private scrubContainer: HTMLElement | null = null;
    private isDragging = false;
    private onMouseMove: ((e: MouseEvent) => void) | null = null;
    private onMouseUp: (() => void) | null = null;

    connectedCallback() {
      this.video = this.querySelector('.video-el') as HTMLVideoElement;
      this.progress = this.querySelector('.progress-bar') as HTMLElement;
      this.skeleton = this.querySelector('.video-skeleton') as HTMLElement;
      this.audioBtn = this.querySelector('.audio-toggle') as HTMLButtonElement;
      this.interactionLayer = this.querySelector('.interaction-layer') as HTMLElement;
      this.scrubContainer = this.querySelector('.scrub-container') as HTMLElement;

      GlobalState.subscribers.add(this);
      this.initEvents();
      this.syncAudio();
      sharedObserver.observe(this);
    }

    disconnectedCallback() {
      sharedObserver.unobserve(this);
      GlobalState.subscribers.delete(this);

      if (GlobalState.activeInstance === this) {
        GlobalState.activeInstance = null;
      }

      if (this.video) {
        this.video.pause();
        this.video.src = "";
        this.video.load();
        this.video.ontimeupdate = null;
        this.video.onplaying = null;
      }

      if (this.audioBtn) this.audioBtn.onclick = null;
      if (this.interactionLayer) this.interactionLayer.onclick = null;
      if (this.scrubContainer) this.scrubContainer.onmousedown = null;

      if (this.onMouseMove) window.removeEventListener('mousemove', this.onMouseMove);
      if (this.onMouseUp) window.removeEventListener('mouseup', this.onMouseUp);

      this.video = null!;
      this.progress = null!;
      this.skeleton = null!;
      this.audioBtn = null!;
      this.interactionLayer = null;
      this.scrubContainer = null;
    }

    public async playInstance() {
      if (GlobalState.activeInstance && GlobalState.activeInstance !== this) {
        GlobalState.activeInstance.pauseInstance();
      }
      
      GlobalState.activeInstance = this;
      if (!this.video.src) this.video.src = this.dataset.src!;
      
      try {
        this.video.muted = GlobalState.isMuted;
        await this.video.play();
      } catch {
        this.video.muted = true;
        this.video.play();
      }
    }

    public pauseInstance() {
      this.video.pause();
      if (GlobalState.activeInstance === this) GlobalState.activeInstance = null;
    }

    private initEvents() {
      this.audioBtn.onclick = (e) => {
        e.stopPropagation();
        GlobalState.toggleAudio();
      };

      if (this.interactionLayer) {
        this.interactionLayer.onclick = () => {
          if (this.video.paused) {
            this.playInstance();
          } else {
            this.pauseInstance();
          }
          this.animateFeedback();
        };
      }

      const handleScrub = (e: any) => {
        if (!this.scrubContainer) return;
        const x = e.touches ? e.touches[0].clientX : e.clientX;
        const rect = this.scrubContainer.getBoundingClientRect();
        const pct = Math.max(0, Math.min(1, (x - rect.left) / rect.width));
        if (isFinite(this.video.duration)) this.video.currentTime = pct * this.video.duration;
      };

      if (this.scrubContainer) {
        this.scrubContainer.onmousedown = (e) => {
          this.isDragging = true;
          this.progress.style.transition = 'none';
          handleScrub(e);
        };
      }
      
      this.onMouseMove = (e: MouseEvent) => { if (this.isDragging) handleScrub(e); };
      this.onMouseUp = () => {
        this.isDragging = false;
        this.progress.style.transition = 'width 0.1s linear';
      };
      window.addEventListener('mousemove', this.onMouseMove);
      window.addEventListener('mouseup', this.onMouseUp);

      this.video.ontimeupdate = () => {
        if (!this.isDragging) {
          const pct = (this.video.currentTime / this.video.duration) * 100;
          this.progress.style.width = `${pct || 0}%`;
        }
      };

      this.video.onplaying = () => {
        this.video.classList.remove('opacity-0');
        this.skeleton.classList.add('opacity-0');
      };
    }

    public syncAudio() {
      this.video.muted = GlobalState.isMuted;
      const hint = this.querySelector('.audio-hint-box') as HTMLElement;
      hint.style.opacity = GlobalState.isMuted ? '1' : '0';
      
      this.audioBtn.classList.toggle('bg-red-600', GlobalState.isMuted);
      this.audioBtn.classList.toggle('bg-white/20', !GlobalState.isMuted);

      const icon = GlobalState.isMuted 
        ? `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636M12 5v14m0-14L7.707 9.293M12 19l-4.293-4.293M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586" stroke-linecap="round" stroke-linejoin="round"/></svg>`
        : `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      this.querySelector('.icon-container')!.innerHTML = icon;
    }

    private animateFeedback() {
      const icon = this.querySelector('.state-icon') as HTMLElement;
      icon.classList.remove('opacity-0', 'scale-50');
      icon.classList.add('opacity-100', 'scale-100');
      setTimeout(() => {
        icon.classList.add('opacity-0', 'scale-50');
        icon.classList.remove('opacity-100', 'scale-100');
      }, 400);
    }
  }

  customElements.define('neuro-stream', NeuroStream);
</script>

<style>
  .video-el { transform: translateZ(0); }
  .progress-bar { transition: width 0.1s linear; will-change: width; }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  .animate-bounce { animation: bounce 1.5s infinite ease-in-out; }
</style>