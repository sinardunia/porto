---
interface Props {
  src: string | null;
}

const { src } = Astro.props;
---

<div class="relative w-full overflow-hidden rounded-sm bg-neutral-100 dark:bg-[#0d0d0d] ring-1 ring-black/5 dark:ring-white/5 shadow-sm aspect-video">
  <iframe
    src={src}
    title="YouTube video player"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    class="absolute inset-0 h-full w-full border-0"
    loading="lazy"
  ></iframe>
</div>
