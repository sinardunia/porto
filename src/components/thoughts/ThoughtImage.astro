---
import { getOptimizedMedia } from "@/lib/thoughts";
interface Props { src: string; isSingleMedia?: boolean; }
const { src, isSingleMedia = false } = Astro.props;
const optimizedSrc = src ? getOptimizedMedia(src, "1200") : "";
---

<neuro-image class="relative flex h-full w-full items-center justify-center overflow-hidden bg-neutral-100 dark:bg-[#0d0d0d]" data-src={src}>
  <div class="skeleton absolute inset-0 animate-pulse bg-neutral-200 dark:bg-neutral-800"></div>
  {src && (
    <img
      src={optimizedSrc}
      loading="lazy"
      decoding="async"
      alt=""
      {/* FORCE GLOBAL CLICK - Pastikan nama fungsi window.openNeuroLightbox */}
      onclick={`window.openNeuroLightbox && window.openNeuroLightbox('${src}')`}
      class:list={[
        "clickable-image opacity-0 transition-opacity duration-500 ease-out z-10 cursor-zoom-in pointer-events-auto",
        isSingleMedia ? "max-h-[600px] w-full object-contain shadow-md" : "absolute inset-0 h-full w-full object-cover",
      ]}
    />
  )}
</neuro-image>

<script>
  class NeuroImage extends HTMLElement {
    constructor() {
      super();
      const img = this.querySelector('img');
      const skeleton = this.querySelector('.skeleton') as HTMLElement;
      const done = () => {
        img?.classList.replace('opacity-0', 'opacity-100');
        if (skeleton) skeleton.style.display = 'none';
      };
      if (img?.complete) done();
      else img?.addEventListener('load', done);
    }
  }
  if (!customElements.get('neuro-image')) customElements.define('neuro-image', NeuroImage);
</script>

<style>
  .clickable-image {
    will-change: opacity, transform;
    transform: translateZ(0);
    -webkit-tap-highlight-color: transparent;
  }
  .clickable-image:active {
    transform: scale(0.97) translateZ(0);
    transition: transform 0.1s ease-out;
  }
</style>