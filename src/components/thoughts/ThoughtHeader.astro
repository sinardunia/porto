---
type Props = {
  time: string;
};

const { time } = Astro.props;
---

<header class="flex items-center justify-between px-1">
  <div class="flex items-center gap-2.5 min-w-0">

    <div class="h-6 w-6 overflow-hidden rounded-full border border-neutral-200/50 dark:border-neutral-800/50">
      <img
        src="/pfp.jpeg"
        alt="Fuji"
        class="h-full w-full object-cover"
      />
    </div>

    <span class="text-xs font-semibold text-neutral-800 dark:text-neutral-200">
      Fuji
    </span>

    <span class="select-none text-[10px] text-neutral-300 dark:text-neutral-700">
      •
    </span>

    <time
      class="truncate whitespace-nowrap text-[10px] font-medium tracking-wide text-neutral-400 dark:text-neutral-500"
    >
      {time}
    </time>

  </div>
</header>