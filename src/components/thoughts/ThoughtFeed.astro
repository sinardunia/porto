---
import ThoughtCard from "./ThoughtCard.astro";
import { queryThoughts } from "@/lib/search";
import type { Thought } from "@/types/thoughts";

interface Props {
  query?: string;
  cursor?: string;
}

const { query = "", cursor = "" } = Astro.props;

const thoughts = await queryThoughts({ query, cursor });

const groupedThoughts = thoughts.reduce<
  { month: string; thoughts: Thought[] }[]
>((groups, thought) => {
  const date = new Date(thought.created_at);
  const month = Number.isNaN(date.getTime())
    ? "Waktu Lampau"
    : new Intl.DateTimeFormat("id-ID", { month: "long", year: "numeric" }).format(date);

  const last = groups.at(-1);
  if (last?.month === month) {
    last.thoughts.push(thought);
  } else {
    groups.push({ month, thoughts: [thought] });
  }
  return groups;
}, []);
---

<div class="w-full min-w-0">
  {thoughts.length > 0 ? (
    <div class="flex flex-col gap-14 w-full min-w-0">
      {groupedThoughts.map((group) => (
        <section class="flex flex-col gap-5 month-section w-full min-w-0">
          <div class="w-full min-w-0 border-b border-neutral-100/70 dark:border-neutral-900/60 pb-1">
            <h2 class="text-[9px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500">
              {group.month}
            </h2>
          </div>
          <div class="flex flex-col gap-8 w-full min-w-0">
            {group.thoughts.map((thought) => (
              <div class="thought-card-wrapper w-full min-w-0 block">
                <ThoughtCard thought={thought} />
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : (
    <div class="py-16 select-none w-full border-t border-neutral-100 dark:border-neutral-900">
      <p class="text-xs text-neutral-400 dark:text-neutral-500">
        Tidak ditemukan hasil pencarian.
      </p>
      <a href="/thoughts" class="text-[10px] uppercase tracking-wider font-bold text-orange-500 mt-2 inline-block hover:underline">
        Reset
      </a>
    </div>
  )}
</div>

<style>
  .thought-card-wrapper {
    content-visibility: auto;
    contain-intrinsic-size: auto 400px;
  }
</style>
