---
type Props = {
  count?: number;
};

const { count = 2 } = Astro.props;
---

<div class="flex flex-col gap-14 w-full">
  {Array.from({ length: count }).map(() => (
    <div class="w-full animate-pulse">
      <div class="mb-3 h-3 w-20 rounded bg-neutral-200 dark:bg-neutral-800" />
      <div class="mb-4 h-4 w-full rounded bg-neutral-200 dark:bg-neutral-800" />
      <div class="mb-4 h-4 w-5/6 rounded bg-neutral-200 dark:bg-neutral-800" />
      <div class="aspect-[4/5] w-full rounded-lg bg-neutral-200 dark:bg-neutral-800" />
    </div>
  ))}
</div>
