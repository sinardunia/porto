---
import type { BlogPostSummary } from "@/types/blog";
import { safeLocaleDate } from "@/lib/blog";

type Props = {
  posts: BlogPostSummary[];
  currentTags?: string[];
};

const { posts, currentTags = [] } = Astro.props;
const currentTagSet = new Set(currentTags.map((t) => t.toLowerCase()));
---

{posts.length > 0 && (
  <aside class="border-t border-neutral-100/50 dark:border-neutral-900/30 pt-8">
    <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500 mb-5">
      Bacaan lainnya
    </h2>
    <ul class="flex flex-col gap-4">
      {posts.map((p) => {
        const dateStr = safeLocaleDate(p.created_at);
        const postTags = (p.tags ?? []).filter((t): t is string => typeof t === "string");
        const matchingTags = postTags.filter((t) => currentTagSet.has(t.toLowerCase()));
        return (
          <li>
            <a href={`/blog/${p.slug}`} class="group block rounded-lg border border-neutral-100/80 dark:border-neutral-800/60 p-3 -mx-1 transition-colors hover:bg-neutral-50/50 dark:hover:bg-neutral-900/30">
              <article class="flex gap-3.5 items-start">
                {p.cover_image_url ? (
                  <img
                    src={p.cover_image_url}
                    alt={p.cover_image_alt || ""}
                    loading="lazy"
                    decoding="async"
                    class="h-16 w-16 shrink-0 rounded-md object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                  />
                ) : (
                  <div class="h-16 w-16 shrink-0 rounded-md bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
                    <svg class="w-5 h-5 text-neutral-300 dark:text-neutral-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0h5.25m-5.25 0l-3 3m3-3v11.25m0-11.25l3 3m-3-3v11.25"/></svg>
                  </div>
                )}
                <div class="min-w-0 flex-1">
                  <h3 class="text-sm font-medium leading-snug text-neutral-800 group-hover:text-neutral-600 dark:text-neutral-200 dark:group-hover:text-neutral-300 transition-colors line-clamp-2">
                    {p.title}
                  </h3>
                  <time class="mt-1 block text-[11px] text-neutral-400 dark:text-neutral-500">
                    {dateStr}
                  </time>
                  {matchingTags.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1">
                      {matchingTags.map((tag) => (
                        <span class="inline-block rounded-full bg-neutral-100 dark:bg-neutral-800 px-2 py-[2px] text-[10px] text-neutral-500 dark:text-neutral-400">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            </a>
          </li>
        );
      })}
    </ul>
  </aside>
)}
