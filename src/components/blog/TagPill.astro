---
interface Props {
  name: string;
  slug: string;
  count?: number;
  href?: string;
  active?: boolean;
  showCount?: boolean;
}

const {
  name,
  slug,
  count,
  href = `/tags/${slug}`,
  active = false,
  showCount = false,
} = Astro.props;

const base =
  "inline-flex min-h-[28px] max-w-full items-center gap-1 rounded-md border px-2.5 py-1 text-[12px] leading-tight font-medium transition-colors";
const truncateClass = "min-w-0 max-w-[180px] truncate sm:max-w-[250px] md:max-w-none";
const idle =
  "border-neutral-200 bg-white text-neutral-600 hover:border-neutral-300 hover:bg-neutral-50 hover:text-neutral-900 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-neutral-500 dark:hover:bg-neutral-800 dark:hover:text-neutral-200";
const current =
  "border-neutral-800 bg-neutral-800 text-neutral-100 dark:border-neutral-200 dark:bg-neutral-100 dark:text-neutral-900";
---

{
  href ? (
    <a
      href={href}
      class:list={[base, active ? current : idle]}
      aria-current={active ? "page" : undefined}
    >
      <span class={truncateClass}>{name}</span>
      {showCount && count !== undefined && (
        <span
          class={[
            "shrink-0 tabular-nums",
            active
              ? "text-neutral-500 dark:text-neutral-400"
              : "text-neutral-500 dark:text-neutral-400",
          ].join(" ")}
        >
          ({count})
        </span>
      )}
    </a>
  ) : (
    <span class:list={[base, active ? current : idle]}>
      <span class={truncateClass}>{name}</span>
      {showCount && count !== undefined && (
        <span class="shrink-0 tabular-nums text-neutral-500 dark:text-neutral-400">({count})</span>
      )}
    </span>
  )
}
