---
interface Props {
  name: string;
  slug: string;
  count?: number;
  href?: string;
  active?: boolean;
  showCount?: boolean;
}

const {
  name,
  slug,
  count,
  href = `/tags/${slug}`,
  active = false,
  showCount = false,
} = Astro.props;

const base =
  "inline-flex min-h-[28px] max-w-full items-center gap-1 rounded border px-2.5 py-1 text-[11px] leading-tight font-medium transition-colors";
const idle =
  "border-neutral-200/90 bg-neutral-50 text-neutral-600 hover:border-neutral-300 hover:bg-white hover:text-neutral-900 dark:border-neutral-800 dark:bg-neutral-900/40 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:bg-neutral-900 dark:hover:text-neutral-200";
const current =
  "border-neutral-800 bg-neutral-800 text-neutral-100 dark:border-neutral-200 dark:bg-neutral-100 dark:text-neutral-900";
---

{
  href ? (
    <a
      href={href}
      class:list={[base, active ? current : idle]}
      aria-current={active ? "page" : undefined}
    >
      <span class="truncate">{name}</span>
      {showCount && count !== undefined && (
        <span
          class:list={[
            "shrink-0 tabular-nums",
            active
              ? "text-neutral-500 dark:text-neutral-400"
              : "text-neutral-500 dark:text-neutral-400",
          ]}
        >
          ({count})
        </span>
      )}
    </a>
  ) : (
    <span class:list={[base, active ? current : idle]}>
      <span class="truncate">{name}</span>
      {showCount && count !== undefined && (
        <span class="shrink-0 tabular-nums text-neutral-500 dark:text-neutral-400">({count})</span>
      )}
    </span>
  )
}
