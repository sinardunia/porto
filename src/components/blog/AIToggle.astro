---
interface Props {
  showAI: boolean;
  hiddenCount: number;
}

const { showAI, hiddenCount } = Astro.props;
---

<button
  id="ai-toggle"
  type="button"
  class:list={[
    "flex items-center gap-2 text-sm transition-colors",
    showAI 
      ? "text-neutral-900 dark:text-neutral-100" 
      : "text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100"
  ]}
  aria-pressed={showAI}
  aria-label={showAI ? "Hide AI-generated posts" : `Show AI-generated posts${hiddenCount > 0 ? ` (${hiddenCount} hidden)` : ""}`}
>
  <div class:list={[
    "relative h-5 w-9 rounded-full transition-colors",
    showAI 
      ? "bg-neutral-800 dark:bg-neutral-600" 
      : "bg-neutral-200 dark:bg-neutral-700"
  ]}>
    <div class:list={[
      "absolute left-1 top-1 h-3 w-3 rounded-full bg-white transition-transform",
      showAI ? "translate-x-4" : ""
    ]}></div>
  </div>
  <span class="select-none">
    Show AI-generated
    {hiddenCount > 0 && !showAI && (
      <span class="ml-1 rounded-full bg-neutral-200 px-1.5 py-0.5 text-xs font-medium text-neutral-700 dark:bg-neutral-700 dark:text-neutral-300">
        {hiddenCount}
      </span>
    )}
  </span>
</button>

<script define:vars={{ showAI }}>
  const toggle = document.getElementById('ai-toggle');
  if (!toggle) return;
  
  toggle.addEventListener('click', () => {
    const url = new URL(window.location.href);
    const currentAI = url.searchParams.get('ai');
    
    if (currentAI === 'on') {
      url.searchParams.set('ai', 'off');
    } else {
      url.searchParams.set('ai', 'on');
    }
    
    localStorage.setItem('showAI', url.searchParams.get('ai') === 'on' ? 'true' : 'false');
    
    // Use View Transitions API for smooth navigation
    if (document.startViewTransition) {
      document.startViewTransition(() => {
        window.location.href = url.toString();
      });
    } else {
      window.location.href = url.toString();
    }
  });
  
  // Sync visual state with localStorage for instant feedback
  const stored = localStorage.getItem('showAI');
  if (stored === 'true' && !showAI) {
    // User preference differs from server state, update visual
    const switchBg = toggle.querySelector('div:first-child');
    const switchKnob = toggle.querySelector('div:first-child > div');
    toggle.classList.remove('text-neutral-600', 'dark:text-neutral-400');
    toggle.classList.add('text-neutral-900', 'dark:text-neutral-100');
    switchBg.classList.remove('bg-neutral-200', 'dark:bg-neutral-700');
    switchBg.classList.add('bg-neutral-800', 'dark:bg-neutral-600');
    switchKnob.classList.add('translate-x-4');
  }
</script>
