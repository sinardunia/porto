---
import BlogListItem from "./BlogListItem.astro";
import { getPublishedBlogPosts, matchesSearch, matchesTag, getAllTags } from "@/lib/blog";
import type { BlogPostSummary } from "@/types/blog";

interface Props {
  search?: string;
  tag?: string;
}

const { search = "", tag = "" } = Astro.props;

let posts: BlogPostSummary[] = [];
let isLoading = true;
let hasError = false;

try {
  const allPosts = await getPublishedBlogPosts(50);
  posts = allPosts;
  if (search) posts = posts.filter((p) => matchesSearch(p, search));
  if (tag) posts = posts.filter((p) => matchesTag(p, tag));
  isLoading = false;
} catch {
  hasError = true;
  isLoading = false;
}

const shouldUseCarousel = posts.length > 6 && !search && !tag;
const allTags = getAllTags(posts);
---

<div class="flex flex-col gap-8 min-h-[50vh]" role="region" aria-live="polite" aria-busy={isLoading}>
  {/* Skeleton loading state - reduces perceived wait time */}
  {isLoading && (
    <div class="flex flex-col gap-4" aria-hidden="true">
      {[1, 2, 3].map(() => (
        <div class="animate-pulse">
          <div class="h-4 w-24 bg-neutral-200 dark:bg-neutral-800 rounded mb-2"></div>
          <div class="h-6 w-3/4 bg-neutral-200 dark:bg-neutral-800 rounded mb-3"></div>
          <div class="h-3 w-full bg-neutral-100 dark:bg-neutral-900 rounded"></div>
        </div>
      ))}
    </div>
  )}
  {allTags.length > 0 && (
    <div class="relative">
      <div class="no-scrollbar flex gap-1.5 sm:gap-2 overflow-x-auto pb-2 -mx-4 px-4 sm:mx-0 sm:px-0">
        {allTags.slice(0, 8).map((t) => (
          <a
            href={`/?tag=${encodeURIComponent(t)}`}
            class:list={[
              "shrink-0 rounded-full border px-2.5 sm:px-3 py-1.5 min-h-[44px] inline-flex items-center text-[11px] sm:text-xs transition-colors touch-manipulation",
              tag === t
                ? "border-text-light bg-text-light text-white dark:border-neutral-100 dark:bg-neutral-100 dark:text-neutral-950"
                : "border-border-light bg-secondary-light text-neutral-500 md:hover:border-neutral-400 md:hover:text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 md:dark:hover:border-neutral-600 md:dark:hover:text-neutral-200",
            ]}
            aria-pressed={tag === t}
          >
            {t}
          </a>
        ))}
        {allTags.length > 8 && (
          <span class="shrink-0 self-center text-[10px] text-neutral-400 dark:text-neutral-600 px-1">
            +{allTags.length - 8}
          </span>
        )}
        {tag && (
          <a
            href="/"
            class="shrink-0 rounded-full border border-border-light px-2.5 sm:px-3 py-1.5 min-h-[44px] inline-flex items-center text-[11px] sm:text-xs text-neutral-400 transition-colors md:hover:text-neutral-700 dark:border-neutral-800 dark:text-neutral-500 md:dark:hover:text-neutral-200"
            aria-label="Clear tag filter"
          >
            &times; Clear
          </a>
        )}
      </div>
      {/* Fade hint for scrollable area on mobile */}
      <div class="absolute right-0 top-0 bottom-2 w-8 bg-gradient-to-l from-white dark:from-[#0a0a0a] to-transparent pointer-events-none sm:hidden" />
    </div>
  )}

  {/* Error state - calming message reduces stress */}
  {hasError && (
    <div class="py-16 text-center" role="status">
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-2">
        Arsip sedang istirahat sejenak.
      </p>
      <p class="text-xs text-neutral-400 dark:text-neutral-500">
        Silakan refresh dalam beberapa saat atau kembali nanti.
      </p>
      <button
        onclick="window.location.reload()"
        class="mt-4 text-xs px-3 py-2 rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors"
      >
        Coba lagi
      </button>
    </div>
  )}

  {!isLoading && !hasError && posts.length > 0 && (
    <section aria-label="Blog posts" class:list={[
      shouldUseCarousel
        ? "-mx-4 sm:-mx-6 flex snap-x gap-3 sm:gap-4 overflow-x-auto px-4 sm:px-6 pb-4"
        : "flex flex-col",
    ]}>
      {posts.map((post) => (
        <div class={shouldUseCarousel ? "w-[85vw] max-w-[20rem] shrink-0 snap-start sm:w-[18rem] md:w-[20rem]" : ""}>
          <BlogListItem post={post} basePath="/blog" />
        </div>
      ))}
    </section>
  )}

  {!isLoading && !hasError && posts.length === 0 && (
    <div class="py-16 select-none w-full border-t border-neutral-100 dark:border-neutral-900">
      <p class="text-xs text-neutral-400 dark:text-neutral-500">
        {search || tag ? "Tidak ditemukan hasil pencarian." : "Belum ada blog post di sini."}
      </p>
      {(search || tag) && (
        <a href="/" class="text-[10px] uppercase tracking-wider font-bold text-orange-500 mt-2 inline-block md:hover:underline">
          Reset
        </a>
      )}
    </div>
  )}
</div>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
