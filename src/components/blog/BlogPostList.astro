---
import BlogListItem from "./BlogListItem.astro";
import {
  getPublishedBlogPostSummaries,
  matchesSearch,
  matchesTag,
  groupPostsByYear,
} from "@/lib/blog";
import { tagToSlug } from "@/lib/tags";
import type { BlogPostSummary } from "@/types/blog";

interface Props {
  search?: string;
  tag?: string;
  /** Pre-filtered list (e.g. tag archive); skips collection fetch when set. */
  posts?: BlogPostSummary[];
}

const { search = "", tag = "", posts: postsProp } = Astro.props;

let allPosts: BlogPostSummary[] = [];
let posts: BlogPostSummary[] = [];
let hasError = false;

try {
  if (postsProp) {
    allPosts = postsProp;
    posts = postsProp;
  } else {
    allPosts = await getPublishedBlogPostSummaries();
    posts = allPosts;
    if (search) posts = posts.filter((p) => matchesSearch(p, search));
    if (tag) posts = posts.filter((p) => matchesTag(p, tag));
  }
} catch {
  hasError = true;
}

const yearGroups = groupPostsByYear(posts);
const visibleSlugs = new Set(posts.map((p) => p.slug));
---

<div
  id="blog-post-list"
  class="flex min-h-[40vh] flex-col gap-10"
  role="region"
  aria-live="polite"
  aria-busy="false"
>
  {
    hasError && (
      <div class="py-16 text-center" role="status">
        <p class="mb-2 text-sm text-neutral-500 dark:text-neutral-400">
          Arsip sedang istirahat sejenak.
        </p>
        <button
          type="button"
          onclick="window.location.reload()"
          class="mt-4 rounded-lg bg-neutral-100 px-3 py-2 text-xs text-neutral-600 transition-colors hover:bg-neutral-200 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-700"
        >
          Coba lagi
        </button>
      </div>
    )
  }

  {
    !hasError && posts.length > 0 && (
      <section aria-label="Articles">
        {yearGroups.map(({ year, posts: yearPosts }) => (
          <div
            data-blog-year
            hidden={!yearPosts.some((p) => visibleSlugs.has(p.slug))}
            class="mb-10 last:mb-0"
          >
            <h2 class="mb-6 mt-6 text-sm font-semibold tabular-nums text-neutral-500 dark:text-neutral-400">
              {year}
            </h2>
            <div class="flex flex-col divide-y divide-neutral-100 dark:divide-neutral-800/80">
              {yearPosts.map((post) => {
                const tags = post.tags.map((t) => tagToSlug(t)).join(",");
                return (
                  <div
                    data-blog-item
                    data-title={post.title}
                    data-description={post.description || ""}
                    data-slug={post.slug}
                    data-tags={tags}
                    hidden={!visibleSlugs.has(post.slug)}
                  >
                    <BlogListItem post={post} />
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </section>
    )
  }

  <div
    data-blog-empty
    hidden={hasError ||
      (postsProp ? posts.length > 0 : search || tag ? posts.length > 0 : allPosts.length > 0)}
    class="border-t border-neutral-100 py-16 dark:border-neutral-900"
  >
    <p class="text-sm text-neutral-500 dark:text-neutral-400">
      {
        search || tag
          ? "No articles match your search."
          : allPosts.length === 0
          ? "No articles published yet."
          : "No articles match your search."
      }
    </p>
    {
      (search || tag) && (
        <a
          href="/"
          class="mt-3 inline-block text-xs font-medium text-neutral-700 underline-offset-2 hover:underline dark:text-neutral-300"
        >
          Clear filters
        </a>
      )
    }
  </div>
</div>
