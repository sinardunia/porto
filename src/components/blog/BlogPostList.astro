---
import BlogListItem from "./BlogListItem.astro";
import { getPublishedBlogPosts, matchesSearch, matchesTag, getAllTags } from "@/lib/blog";
import type { BlogPostSummary } from "@/types/blog";

interface Props {
  search?: string;
  tag?: string;
}

const { search = "", tag = "" } = Astro.props;

let allPosts: BlogPostSummary[] = [];
let posts: BlogPostSummary[] = [];
let hasError = false;

try {
  allPosts = await getPublishedBlogPosts(50);
  posts = allPosts;
  if (search) posts = posts.filter((p) => matchesSearch(p, search));
  if (tag) posts = posts.filter((p) => matchesTag(p, tag));
} catch {
  hasError = true;
}

const shouldUseCarousel = posts.length > 6 && !search && !tag;
const allTags = getAllTags(allPosts);
const visibleSlugs = new Set(posts.map((p) => p.slug));
---

<div
  id="blog-post-list"
  class="flex min-h-[50vh] flex-col gap-8"
  role="region"
  aria-live="polite"
  aria-busy="false"
>
  {allTags.length > 0 && (
    <div class="relative">
      <div class="no-scrollbar -mx-4 flex gap-1.5 overflow-x-auto px-4 pb-2 sm:mx-0 sm:gap-2 sm:px-0">
        {allTags.slice(0, 8).map((t) => (
          <a
            href={`/?tag=${encodeURIComponent(t)}`}
            class:list={[
              "inline-flex min-h-[44px] shrink-0 touch-manipulation items-center rounded-full border px-2.5 py-1.5 text-[11px] transition-colors sm:px-3 sm:text-xs",
              tag === t
                ? "border-text-light bg-text-light text-white dark:border-neutral-100 dark:bg-neutral-100 dark:text-neutral-950"
                : "border-border-light bg-secondary-light text-neutral-500 md:hover:border-neutral-400 md:hover:text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 md:dark:hover:border-neutral-600 md:dark:hover:text-neutral-200",
            ]}
            aria-pressed={tag === t}
          >
            {t}
          </a>
        ))}
        {allTags.length > 8 && (
          <span class="shrink-0 self-center px-1 text-[10px] text-neutral-400 dark:text-neutral-600">
            +{allTags.length - 8}
          </span>
        )}
        {tag && (
          <a
            href="/"
            class="inline-flex min-h-[44px] shrink-0 items-center rounded-full border border-border-light px-2.5 py-1.5 text-[11px] text-neutral-400 transition-colors md:hover:text-neutral-700 dark:border-neutral-800 dark:text-neutral-500 md:dark:hover:text-neutral-200 sm:px-3 sm:text-xs"
            aria-label="Clear tag filter"
          >
            &times; Clear
          </a>
        )}
      </div>
      <div class="pointer-events-none absolute bottom-2 right-0 top-0 w-8 bg-gradient-to-l from-white to-transparent sm:hidden dark:from-[#0a0a0a]" />
    </div>
  )}

  {hasError && (
    <div class="py-16 text-center" role="status">
      <p class="mb-2 text-sm text-neutral-500 dark:text-neutral-400">
        Arsip sedang istirahat sejenak.
      </p>
      <p class="text-xs text-neutral-400 dark:text-neutral-500">
        Silakan refresh dalam beberapa saat atau kembali nanti.
      </p>
      <button
        type="button"
        onclick="window.location.reload()"
        class="mt-4 rounded-lg bg-neutral-100 px-3 py-2 text-xs text-neutral-600 transition-colors hover:bg-neutral-200 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-700"
      >
        Coba lagi
      </button>
    </div>
  )}

  {!hasError && allPosts.length > 0 && (
    <section
      aria-label="Blog posts"
      class:list={[
        shouldUseCarousel
          ? "-mx-4 flex snap-x gap-3 overflow-x-auto px-4 pb-4 sm:-mx-6 sm:gap-4 sm:px-6"
          : "flex flex-col",
      ]}
    >
      {allPosts.map((post) => {
        const tags = Array.isArray(post.tags)
          ? post.tags.filter((t): t is string => typeof t === "string")
          : [];
        return (
          <div
            data-blog-item
            data-title={post.title}
            data-excerpt={post.excerpt || ""}
            data-slug={post.slug}
            data-tags={tags.join(",")}
            hidden={!visibleSlugs.has(post.slug)}
            class:list={[shouldUseCarousel ? "w-[85vw] max-w-[20rem] shrink-0 snap-start sm:w-[18rem] md:w-[20rem]" : ""]}
          >
            <BlogListItem post={post} basePath="/blog" />
          </div>
        );
      })}
    </section>
  )}

  <div
    data-blog-empty
    hidden={hasError || posts.length > 0}
    class="w-full select-none border-t border-neutral-100 py-16 dark:border-neutral-900"
  >
    <p class="text-xs text-neutral-400 dark:text-neutral-500">
      {search || tag ? "Tidak ditemukan hasil pencarian." : "Belum ada blog post di sini."}
    </p>
    {(search || tag) && (
      <a
        href="/"
        class="mt-2 inline-block text-[10px] font-bold uppercase tracking-wider text-orange-500 md:hover:underline"
      >
        Reset
      </a>
    )}
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
