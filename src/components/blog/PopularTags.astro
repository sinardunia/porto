---
import TagPill from "./TagPill.astro";
import { getPopularTags } from "@/lib/blog";

interface Props {
  posts: import("@/types/blog").BlogPostSummary[];
}

const { posts } = Astro.props;
const tags = getPopularTags(posts, 5);
---

{tags.length > 0 && (
  <nav aria-label="Popular tags" class="w-full min-w-0">
    <div class="flex flex-col gap-1.5 sm:flex-row sm:items-center sm:justify-between">
      <ul class="flex min-w-0 flex-wrap items-center gap-1.5">
        {tags.map(({ name, slug, count }, index) => (
          <li
            class:list={[
              index >= 3 && "hidden sm:block",
            ]}
          >
            <TagPill name={name} slug={slug} count={count} showCount={true} />
          </li>
        ))}
      </ul>
      <a
        href="/tags"
        class="mt-2 shrink-0 self-start text-xs text-neutral-500 underline-offset-2 transition-colors hover:text-neutral-800 hover:underline dark:text-neutral-500 dark:hover:text-neutral-300 sm:mt-0"
        data-astro-prefetch="hover"
      >
        View All Tags →
      </a>
    </div>
  </nav>
)}
