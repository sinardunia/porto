---
import type { BlogPostSummary } from "@/types/blog";

type Props = {
  post: BlogPostSummary;
  basePath?: string;
};

const { post, basePath = "/blog" } = Astro.props;
const createdAt = new Date(post.created_at);
const formattedDate = Number.isNaN(createdAt.getTime())
  ? post.created_at
  : new Intl.DateTimeFormat("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    }).format(createdAt);

const safeTags = Array.isArray(post.tags)
  ? post.tags.filter((t): t is string => typeof t === "string")
  : [];
---

<a href={`${basePath}/${post.slug}`} class="group block border-b border-border-light/70 py-7 dark:border-neutral-800/80">
  <article class="flex gap-5">
    <div class="min-w-0 flex-1">
      <h2 class="text-xl font-semibold leading-8 text-neutral-900 group-hover:text-neutral-700 dark:text-neutral-100 dark:group-hover:text-neutral-300">
        {post.title}
      </h2>

      {post.excerpt && (
        <p class="mt-2 line-clamp-3 text-sm leading-7 text-neutral-500 dark:text-neutral-400">
          {post.excerpt}
        </p>
      )}

      <time datetime={post.created_at} class="mt-3 block text-xs text-neutral-400 dark:text-neutral-600">
        {formattedDate}
      </time>

      {safeTags.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-1.5">
          {safeTags.map((tag) => (
            <span class="rounded-full border border-border-light bg-secondary-light px-2 py-0.5 text-[11px] text-neutral-500 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    {post.cover_image_url && (
      <img
        src={post.cover_image_url}
        alt={post.cover_image_alt || ""}
        loading="lazy"
        decoding="async"
        class="mt-1 h-20 w-20 shrink-0 rounded-lg object-cover opacity-90 sm:h-24 sm:w-24"
      />
    )}
  </article>
</a>
