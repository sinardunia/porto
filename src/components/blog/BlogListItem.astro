---
import CoverImage from "./CoverImage.astro";
import ThumbnailFrame from "./ThumbnailFrame.astro";
import TagPill from "./TagPill.astro";
import type { BlogPostSummary } from "@/types/blog";
import { humanizeTimestamp, safeLocaleDate } from "@/lib/blog";
import { tagToSlug } from "@/lib/tags";

type Props = {
  post: BlogPostSummary;
};

const { post } = Astro.props;
const humanized = humanizeTimestamp(post.pubDatetime, "id-ID");
const fullDate = safeLocaleDate(post.pubDatetime, "id-ID", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const shortDate = safeLocaleDate(post.pubDatetime, "id-ID", { day: "numeric", month: "short" });
const displayTags = post.tags.slice(0, 2);
---

<article class="group relative py-5 sm:py-6">
  <div class="relative flex items-start gap-3 sm:gap-4">
    <ThumbnailFrame size="lg">
      <CoverImage
        src={post.coverImage}
        alt=""
        width={80}
        height={80}
        sizes="(max-width: 640px) 64px, 80px"
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
      />
    </ThumbnailFrame>

    <div class="min-w-0 flex-1 pt-0.5">
      <h3
        class="text-[15px] font-semibold leading-snug text-neutral-900 transition-colors group-hover:text-neutral-600 dark:text-neutral-100 dark:group-hover:text-neutral-300 sm:text-base"
      >
        {post.title}
      </h3>

      {
        post.description && (
          <p class="mt-1.5 line-clamp-2 min-w-0 break-words text-sm leading-relaxed text-neutral-500 dark:text-neutral-500">
            {post.description}
          </p>
        )
      }

      <div
        class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1.5 text-xs text-neutral-500 dark:text-neutral-400 sm:gap-x-3 sm:gap-y-2"
        style="min-width: 0; max-width: 100%;"
      >
        <time datetime={post.pubDatetime} title={fullDate} class="sm:hidden shrink-0 whitespace-nowrap tabular-nums">{shortDate}</time>
        <time datetime={post.pubDatetime} title={fullDate} class="hidden sm:inline shrink-0 whitespace-nowrap tabular-nums"
          >{humanized}</time
        >
        {post.aiGenerated && (
          <span class="inline-flex items-center rounded-full bg-neutral-100 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400">
            AI
          </span>
        )}
        {
          displayTags.map((tag) => (
            <span class="relative z-20 shrink-0">
              <TagPill name={tag} slug={tagToSlug(tag)} />
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <a
    href={`/blog/${post.slug}`}
    class="no-typewriter absolute inset-0 z-10 rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 dark:focus-visible:outline-neutral-500"
    aria-label={post.title}
    data-astro-prefetch="hover"
  >
    <span class="sr-only">{post.title}</span>
  </a>
</article>
