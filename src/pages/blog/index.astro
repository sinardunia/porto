---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import BlogSkeleton from "@/components/skeletons/BlogSkeleton.astro";

export const prerender = false;

const query = Astro.url.searchParams.get("q")?.trim() || "";
const activeTag = Astro.url.searchParams.get("tag")?.trim() || "";

const hiddenInputs: { name: string; value: string }[] = [];
if (activeTag) hiddenInputs.push({ name: "tag", value: activeTag });

const clearHref = activeTag ? `/blog?tag=${encodeURIComponent(activeTag)}` : "/blog";
---

<Layout
  title={activeTag ? `${activeTag} — Blog` : "Blog"}
  description={activeTag ? `Tulisan yang ditandai dengan "${activeTag}".` : "Blog"}
>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 px-5 pb-24 pt-0 min-w-0 overflow-x-hidden box-border md:px-0">
    <header class="pt-10 pb-6 w-full min-w-0 overflow-hidden border-b border-neutral-100/50 dark:border-neutral-900/30">
      <div class={`flex items-center gap-2 ${activeTag ? "mb-4" : ""}`}>
        <h1 class="text-sm font-black uppercase tracking-[0.2em] text-neutral-800 dark:text-neutral-100">
          {activeTag ? `Tag: ${activeTag}` : "Blog"}
        </h1>
        {!activeTag && (
          <span class="h-1 w-1 rounded-full bg-orange-500 animate-pulse"></span>
        )}
      </div>

      {activeTag && (
        <div class="max-w-[420px] space-y-3">
          <p class="text-[13px] leading-relaxed text-neutral-500 dark:text-neutral-400 font-medium italic">
            Tulisan yang ditandai dengan "{activeTag}".
          </p>
        </div>
      )}
    </header>

    <SearchInput
      action="/blog"
      value={query}
      placeholder="Cari tulisan..."
      clearHref={query ? clearHref : undefined}
      hiddenInputs={hiddenInputs}
    />

    <BlogPostList server:defer search={query} tag={activeTag}>
      <BlogSkeleton slot="fallback" count={3} />
    </BlogPostList>
  </main>
</Layout>
