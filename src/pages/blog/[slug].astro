---
import Layout from "@/layouts/Layout.astro";
import { createSupabaseClient } from "@/lib/supabase";
import { withTimeout, sanitizeRenderedHtml } from "@/lib/security";
import { marked } from "marked";

export const prerender = false;

const { slug } = Astro.params;

if (!slug || typeof slug !== "string") {
  return Astro.redirect("/blog");
}

const getPost = async () => {
  try {
    const supabase = createSupabaseClient();
    const { data, error } = await withTimeout(
      supabase
        .from("blog_posts")
        .select("id, slug, title, excerpt, content, cover_image_url, cover_image_alt, tags, created_at, updated_at, is_published")
        .eq("slug", slug)
        .eq("is_published", true)
        .single(),
      10000,
      "Blog post fetch"
    );

    if (error || !data) {
      console.warn("Blog post not found:", error?.message || slug);
      return null;
    }

    return data;
  } catch (error) {
    console.warn(
      "Blog post fetch failed:",
      error instanceof Error ? error.message : "Unknown error"
    );
    return null;
  }
};

const post = await getPost();

if (!post) {
  return Astro.redirect("/blog");
}

const safeTags = Array.isArray(post.tags) ? post.tags.filter((t): t is string => typeof t === "string") : [];
---

<Layout title={post.title}>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <article class="flex flex-col gap-8">
      <header class="flex flex-col gap-3">
        <a
          href="/blog"
          class="text-sm text-neutral-400 transition-colors hover:text-neutral-700 dark:text-neutral-500 dark:hover:text-neutral-300"
        >
          &larr; Back to blog
        </a>

        <h1 class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
          {post.title}
        </h1>

        <time
          datetime={post.created_at}
          class="text-sm text-neutral-400 dark:text-neutral-500"
        >
          {new Date(post.created_at).toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          })}
        </time>

        {safeTags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {safeTags.map((tag) => (
              <a
                href={`/blog?tag=${encodeURIComponent(tag)}`}
                class="rounded-full border border-border-light bg-secondary-light px-3 py-1 text-xs text-neutral-500 transition-colors hover:border-neutral-400 hover:text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:text-neutral-200"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      {post.cover_image_url && (
        <img
          src={post.cover_image_url}
          alt={post.cover_image_alt || ""}
          class="w-full rounded-lg object-cover"
          loading="eager"
          decoding="async"
        />
      )}

      <div
        class="prose prose-neutral max-w-none dark:prose-invert"
        set:html={sanitizeRenderedHtml(marked.parse(post.content))}
      />
    </article>
  </main>
</Layout>
