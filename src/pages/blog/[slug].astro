---
import Layout from "@/layouts/Layout.astro";
import { getBlogPostBySlug, estimateReadTime } from "@/lib/blog";
import { sanitizeRenderedHtml, convertYouTubeLinks } from "@/lib/security";
import { SITE_URL } from "@/data/config";
import "@/styles/post.css";

export const prerender = false;

const { slug } = Astro.params;

if (!slug || typeof slug !== "string") {
  return Astro.redirect("/blog");
}

const post = await getBlogPostBySlug(slug);

if (!post) {
  Astro.response.status = 404;
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=30, stale-while-revalidate=300"
  );
}

if (post) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=60, stale-while-revalidate=600"
  );
}

const safeTags = post && Array.isArray(post.tags) ? post.tags.filter((t): t is string => typeof t === "string") : [];
const readTime = post ? estimateReadTime(post.content || "") : 0;
const dateStr = post ? new Date(post.created_at).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }) : "";
const isoDate = post ? new Date(post.created_at).toISOString() : "";
const description = post?.excerpt || (post ? `${post.title}. A ${readTime}-minute read.` : "The requested post could not be found.");
const ogImage = post?.cover_image_url || undefined;

let finalContent = "";
if (post) {
  const { marked } = await import("marked");
  const renderedContent = await marked.parse(post.content);
  const sanitizedContent = await sanitizeRenderedHtml(renderedContent);
  finalContent = convertYouTubeLinks(sanitizedContent);
}

const jsonLd = post ? {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description,
  image: ogImage,
  datePublished: isoDate,
  dateModified: post.updated_at ? new Date(post.updated_at).toISOString() : isoDate,
  author: {
    "@type": "Person",
    name: "Fuji Halim Rabani",
    url: SITE_URL,
  },
  publisher: {
    "@type": "Person",
    name: "Fuji Halim Rabani",
    url: SITE_URL,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(`/blog/${post.slug}`, SITE_URL).toString(),
  },
  keywords: safeTags.join(", "),
} : undefined;
---

<Layout
  title={post?.title ?? "Not Found"}
  description={description}
  noindex={!post}
  og={post ? { title: post.title, description, image: ogImage, type: "article" } : undefined}
  jsonLd={jsonLd}
>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 px-5 pb-24 pt-0 min-w-0 overflow-x-hidden box-border md:px-0">
    {post ? (
      <article class="flex flex-col gap-8" itemscope itemtype="https://schema.org/Article">
        <header class="pt-10 pb-6 w-full min-w-0 overflow-hidden border-b border-neutral-100/50 dark:border-neutral-900/30">
          <div class="flex items-center gap-2 mb-4">
            <a
              href="/blog"
              class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 hover:text-neutral-700 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors"
            >
              Blog
            </a>
            <span class="text-neutral-300 dark:text-neutral-700">/</span>
            <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500">Article</span>
          </div>

          <h1
            class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
            itemprop="headline"
          >
            {post.title}
          </h1>

          <div class="mt-3 flex items-center gap-2 text-xs text-neutral-400 dark:text-neutral-500">
            <time datetime={post.created_at} itemprop="datePublished">
              {dateStr}
            </time>
            <span class="text-neutral-300 dark:text-neutral-700">·</span>
            <span>{readTime} min read</span>
          </div>

          {safeTags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {safeTags.map((tag) => (
                <a
                  href={`/blog?tag=${encodeURIComponent(tag)}`}
                  class="rounded-full border border-border-light bg-secondary-light px-3 py-1 text-xs text-neutral-500 transition-colors hover:border-neutral-400 hover:text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:text-neutral-200"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}
        </header>

        {post.cover_image_url && (
          <figure class="relative aspect-[16/9] w-full overflow-hidden rounded-lg bg-neutral-100 dark:bg-neutral-900" itemprop="image">
            <img
              src={post.cover_image_url}
              alt={post.cover_image_alt || post.title}
              class="absolute inset-0 h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </figure>
        )}

        <div
          class="prose prose-neutral prose-lg dark:prose-invert post"
          itemprop="articleBody"
          set:html={finalContent}
        />
      </article>
    ) : (
      <div class="pt-10 pb-6 border-b border-neutral-100/50 dark:border-neutral-900/30">
        <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100 mb-2">
          Post tidak ditemukan
        </h1>
        <p class="text-sm text-neutral-500 mb-4">
          Sepertinya post yang kamu cari sudah dihapus atau belum dipublikasikan.
        </p>
        <a href="/blog" class="text-xs font-bold uppercase tracking-wider text-orange-500 hover:underline">
          ← Kembali ke Blog
        </a>
      </div>
    )}
  </main>
</Layout>

<style is:global>
  .youtube-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #0a0a0a;
    margin: 1.5rem 0;
  }
  .youtube-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .youtube-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    cursor: pointer;
  }
  .youtube-placeholder::before {
    content: '';
    width: 0;
    height: 0;
    border-left: 20px solid rgba(255, 255, 255, 0.9);
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
    margin-left: 4px;
  }
  .youtube-placeholder::after {
    content: 'YouTube';
    position: absolute;
    bottom: 12px;
    left: 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
</style>

<script>
  document.querySelectorAll('.youtube-embed').forEach((el) => {
    const id = el.getAttribute('data-id');
    if (!id) return;

    const placeholder = el.querySelector('.youtube-placeholder');
    if (!placeholder) return;

    placeholder.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&autoplay=1`;
      iframe.title = 'YouTube video player';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      placeholder.replaceWith(iframe);
    }, { once: true });
  });
</script>
