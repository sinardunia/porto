---
import Layout from "@/layouts/Layout.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import ShareButtons from "@/components/blog/ShareButtons.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import { getBlogPostBySlug, getPublishedBlogPostSummaries, getRelatedPosts, estimateReadTime, safeLocaleDate, safeIsoDate, humanizeTimestamp } from "@/lib/blog";
import { sanitizeRenderedHtml } from "@/lib/security";
import { SITE_URL } from "@/data/config";
import "@/styles/post.css";

export const prerender = false;

const { slug } = Astro.params;

if (!slug || typeof slug !== "string") {
  return Astro.redirect("/blog");
}

const post = await getBlogPostBySlug(slug);

// Fetch for related posts
let relatedPosts: Awaited<ReturnType<typeof getPublishedBlogPostSummaries>> = [];
if (post) {
  try {
    const allPosts = await getPublishedBlogPostSummaries(50);
    relatedPosts = getRelatedPosts(post, allPosts, 4);
  } catch {
    relatedPosts = [];
  }
}

if (!post) {
  Astro.response.status = 404;
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=30, stale-while-revalidate=300"
  );
}

if (post) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=60, stale-while-revalidate=600"
  );
}

const safeTags = post && Array.isArray(post.tags) ? post.tags.filter((t): t is string => typeof t === "string") : [];
const readTime = post ? estimateReadTime(post.content || "") : 0;
const dateStr = post ? humanizeTimestamp(post.created_at, "id-ID") : "";
const fullDate = post ? safeLocaleDate(post.created_at, "id-ID", { day: "numeric", month: "long", year: "numeric" }) : "";
const isoDate = post ? safeIsoDate(post.created_at) : "";
const description = post?.excerpt || (post ? `${post.title}. A ${readTime}-minute read.` : "The requested post could not be found.");
const ogImage = post?.cover_image_url || undefined;

let finalContent = "";
if (post) {
  try {
    const { marked } = await import("marked");
    const renderedContent = await marked.parse(post.content || "");
    finalContent = await sanitizeRenderedHtml(renderedContent);
  } catch {
    finalContent = `<p class="text-neutral-400 italic">Failed to load content.</p>`;
  }
}

const jsonLd = post ? {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description,
  image: ogImage,
  datePublished: isoDate,
  dateModified: safeIsoDate(post.updated_at) || isoDate,
  author: {
    "@type": "Person",
    name: "Fuji Halim Rabani",
    url: SITE_URL,
  },
  publisher: {
    "@type": "Person",
    name: "Fuji Halim Rabani",
    url: SITE_URL,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(`/blog/${post.slug}`, SITE_URL).toString(),
  },
  keywords: safeTags.join(", "),
} : undefined;
---

<Layout
  title={post?.title ?? "Not Found"}
  description={description}
  noindex={!post}
  og={post ? { title: post.title, description, image: ogImage, type: "article" } : undefined}
  jsonLd={jsonLd}
>
  {post && <ReadingProgress />}
  <main class="px-5 sm:px-6 lg:px-8 pt-2 w-full">
    {post ? (
      <>
        {/* Medium-style article container - max-w-[680px] */}
        <article 
          class="mx-auto max-w-[680px]" 
          itemscope 
          itemtype="https://schema.org/Article"
        >
          {/* Header - Sans-serif for meta/headings */}
          <header class="mb-8 md:mb-10">
            {/* Navigation */}
            <nav class="mb-6">
              <a 
                href="/" 
                class="inline-flex items-center gap-1 text-sm text-neutral-500 dark:text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-400 transition-colors min-h-[44px] min-w-[44px]"
                data-astro-prefetch="hover"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                <span>Home</span>
              </a>
            </nav>

            {/* Title - Sans-serif, prominent */}
            <h1
              class="text-3xl md:text-4xl lg:text-[42px] font-bold text-neutral-900 dark:text-neutral-100 leading-[1.15] tracking-tight font-sans"
              itemprop="headline"
            >
              {post.title}
            </h1>

            {/* Meta - Sans-serif, responsive */}
            <div class="mt-5 flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-2 sm:gap-3 text-sm sm:text-base text-neutral-500 dark:text-neutral-500 font-sans">
              <div class="flex items-center gap-2 sm:gap-3">
                <time datetime={post.created_at} itemprop="datePublished" title={fullDate}>
                  {dateStr}
                </time>
                <span class="text-neutral-400">·</span>
                <span>{readTime} min read</span>
              </div>
              {safeTags.length > 0 && (
                <div class="flex items-center gap-2 sm:gap-3">
                  <span class="text-neutral-400 hidden sm:inline">·</span>
                  <div class="flex flex-wrap gap-x-3 gap-y-1">
                    {safeTags.slice(0, 3).map((tag) => (
                      <span class="text-neutral-600 dark:text-neutral-400">#{tag}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>

          </header>

          {/* Featured Image */}
          {post.cover_image_url && (
            <figure class="mb-8 md:mb-10" itemprop="image">
              <div 
                class="w-full overflow-hidden rounded-lg bg-neutral-100 dark:bg-neutral-900 relative"
                style="aspect-ratio: 16/9;"
              >
                <img
                  src={post.cover_image_url}
                  alt={post.cover_image_alt || post.title}
                  width={1200}
                  height={675}
                  loading="eager"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover"
                  style="min-height: 100%; min-width: 100%;"
                />
              </div>
            </figure>
          )}

          {/* Article Content - Serif font for body text (Medium style) */}
          <div
            class="post prose prose-lg max-w-none"
            itemprop="articleBody"
            set:html={finalContent}
          />

          {/* Share - Minimal icon-only */}
          <div class="mt-16 pt-10 border-t border-neutral-200 dark:border-neutral-800">
            <div class="flex items-center justify-between gap-4">
              <span class="text-xs text-neutral-400 dark:text-neutral-500">Share</span>
              <ShareButtons url={`${SITE_URL}/blog/${post.slug}`} title={post.title} />
            </div>
          </div>

          {/* Related Posts */}
          {relatedPosts.length > 0 && (
            <RelatedPosts posts={relatedPosts} />
          )}

        </article>

        {/* Image Lightbox */}
        <div id="image-lightbox" class="lightbox-overlay" onclick="closeImageLightbox()">
          <button
            class="lightbox-close"
            onclick="event.stopPropagation(); closeImageLightbox()"
            aria-label="Close lightbox"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
          <img id="lightbox-img" src="" alt=""/>
        </div>

        {/* Lightbox Script */}
        <script is:inline>
          (function() {
            // Add click handlers to all images in post content
            function initImageLightbox() {
              const postContent = document.querySelector('.post');
              if (!postContent) return;

              const images = postContent.querySelectorAll('img');
              images.forEach(function(img) {
                img.addEventListener('click', function() {
                  openImageLightbox(img.src, img.alt);
                });
              });
            }

            // Initialize when DOM is ready
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', initImageLightbox);
            } else {
              initImageLightbox();
            }

            // Also re-initialize after Astro page transitions
            document.addEventListener('astro:page-load', initImageLightbox);
          })();

          function openImageLightbox(src, alt) {
            const lightbox = document.getElementById('image-lightbox');
            const img = document.getElementById('lightbox-img');
            if (!lightbox || !img) return;

            img.src = src;
            img.alt = alt || '';
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
          }

          function closeImageLightbox() {
            const lightbox = document.getElementById('image-lightbox');
            if (!lightbox) return;

            lightbox.classList.remove('active');
            document.body.style.overflow = '';
          }

          // Expose for global keyboard shortcuts
          window.closeBlogLightbox = closeImageLightbox;

          // Keyboard shortcuts
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
              closeImageLightbox();
            }
          });
        </script>
      </>
    ) : (
      <div class="mx-auto max-w-[680px] py-12 text-center">
        <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-3">
          Not found
        </h1>
        <p class="text-lg text-neutral-500 dark:text-neutral-400 mb-8">
          The post you're looking for doesn't exist.
        </p>
        <a 
          href="/" 
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-medium text-neutral-700 dark:text-neutral-300 bg-neutral-100 dark:bg-neutral-800 rounded-lg hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors min-h-[44px] min-w-[44px]"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to home
        </a>
      </div>
    )}
  </main>
</Layout>

