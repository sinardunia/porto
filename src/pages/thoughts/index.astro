---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import ThoughtFeed from "@/components/thoughts/ThoughtFeed.astro";
import ThoughtSkeleton from "@/components/skeletons/ThoughtSkeleton.astro";
import "@/styles/post.css";

export const prerender = false;

const searchQuery = Astro.url.searchParams.get("q")?.trim() || "";
const cursorQuery = Astro.url.searchParams.get("before")?.trim() || "";

// Cache: lebih pendek kalau ada filter aktif
Astro.response.headers.set(
  "Cache-Control",
  searchQuery || cursorQuery
    ? "public, max-age=30, stale-while-revalidate=300"
    : "public, max-age=60, stale-while-revalidate=600"
);
---

<Layout title="Thoughts" description="Butuh waktu singkat untuk menulisnya, tapi bisa mengabadikan momen selamanya. Di sini, kamu bisa baca pikiran random, curahan hati, atau apapun yang lagi ada di kepalaku.">
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 px-5 pb-24 pt-0 min-w-0 overflow-x-hidden box-border md:px-0">
    <header class="pt-10 pb-6 w-full min-w-0 overflow-hidden border-b border-neutral-100/50 dark:border-neutral-900/30">
      <div class="flex items-center gap-2">
        <h1 class="text-sm font-black uppercase tracking-[0.2em] text-neutral-800 dark:text-neutral-100">
          Thoughts
        </h1>
        <span class="h-1 w-1 rounded-full bg-orange-500 animate-pulse"></span>
      </div>
      <div class="max-w-[640px] space-y-3 mt-4">
        <p class="text-[13px] leading-relaxed text-neutral-500 dark:text-neutral-400">
        Tempat singgah untuk catatan-catatan yang tidak cukup panjang menjadi tulisan.
    </p>
      </div>
    </header>

    <SearchInput
      action="/thoughts"
      value={searchQuery}
      placeholder="Cari potongan memori..."
      clearHref={searchQuery ? "/thoughts" : undefined}
    />

    <ThoughtFeed server:defer query={searchQuery} cursor={cursorQuery}>
      <ThoughtSkeleton slot="fallback" count={2} />
    </ThoughtFeed>
  </main>
</Layout>

<div id="image-lightbox" class="fixed inset-0 z-[999999] bg-black/95 backdrop-blur-md hidden opacity-0 flex items-center justify-center transition-all duration-300 select-none pointer-events-auto" onclick="window.closeNeuroLightbox()">
  <button
    id="lightbox-close"
    type="button"
    class="absolute top-6 right-6 z-[1000001] flex h-12 w-12 items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-all active:scale-90 border border-white/10 cursor-pointer pointer-events-auto"
    onclick="event.stopPropagation(); window.closeNeuroLightbox();"
    aria-label="Close"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <div class="relative flex h-full w-full items-center justify-center p-4">
    <img
      id="lightbox-img"
      class="max-w-[95vw] max-h-[90vh] object-contain rounded-sm shadow-2xl transition-all duration-300 scale-95 pointer-events-auto"
      src=""
      alt=""
      onclick="event.stopPropagation()"
    />
  </div>
</div>

<style>
  main { -webkit-tap-highlight-color: transparent; }
  #image-lightbox {
    position: fixed !important;
    top: 0 !important; left: 0 !important;
    width: 100vw !important; height: 100vh !important;
  }
  #lightbox-close, #lightbox-img { pointer-events: auto !important; }
</style>

<script is:inline>
  window.openNeuroLightbox = function(src) {
    const lb = document.getElementById('image-lightbox');
    const img = document.getElementById('lightbox-img');
    if (!lb || !img) return;
    img.src = src;
    lb.classList.remove('hidden');
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    setTimeout(() => {
      lb.classList.add('opacity-100');
      img.classList.replace('scale-95', 'scale-100');
    }, 10);
    window.history.pushState({ lightboxOpen: true }, '');
  };

  window.closeNeuroLightbox = function() {
    const lb = document.getElementById('image-lightbox');
    const img = document.getElementById('lightbox-img');
    if (!lb || !img) return;
    lb.classList.remove('opacity-100');
    img.classList.replace('scale-100', 'scale-95');
    setTimeout(() => {
      lb.classList.add('hidden');
      lb.style.display = 'none';
      img.src = "";
    }, 300);
    document.body.style.overflow = '';
  };

  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;
    const trigger = target.closest('.clickable-image');
    if (trigger) {
      const src = trigger.getAttribute('data-raw-src') || trigger.src;
      window.openNeuroLightbox(src);
    }
  });

  window.addEventListener('popstate', () => {
    const lb = document.getElementById('image-lightbox');
    if (lb && lb.style.display === 'flex') window.closeNeuroLightbox();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') window.closeNeuroLightbox();
  });
</script>
