---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import PopularTags from "@/components/blog/PopularTags.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import { getPublishedBlogPostSummaries } from "@/lib/blog";
import { tagToSlug } from "@/lib/tags";
import type { BlogPostSummary } from "@/types/blog";
import { SITE_URL } from "@/data/config";
import { AUTHOR } from "@/data/author";

export const prerender = false;

const legacyTag = Astro.url.searchParams.get("tag")?.trim();
if (legacyTag) {
  return Astro.redirect(`/tags/${tagToSlug(legacyTag)}`, 301);
}

const query = Astro.url.searchParams.get("q")?.trim() || "";
const clearHref = "/";

let allPosts: BlogPostSummary[] = [];
try {
  allPosts = await getPublishedBlogPostSummaries();
} catch {
  allPosts = [];
}

const recentPosts = allPosts.slice(0, 2);

Astro.response.headers.set(
  "Cache-Control",
  query
    ? "public, max-age=30, stale-while-revalidate=300"
    : "public, max-age=60, stale-while-revalidate=600"
);

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Blogs",
  description: "A quiet personal archive of thoughts, writing, and experiments.",
  url: SITE_URL,
  publisher: {
    "@type": "Person",
    name: AUTHOR.name,
    url: SITE_URL,
  },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${SITE_URL}/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
  inLanguage: "id",
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Articles", item: SITE_URL },
  ],
};

const jsonLd = [websiteJsonLd, breadcrumbJsonLd];
const pageTitle = "Articles";
const pageDescription = "Catatan yang kebetulan ditulis. Jika bermanfaat, alhamdulillah.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
>
  <div class="flex w-full min-w-0 flex-col gap-8 pb-12">
    <section aria-labelledby="articles-heading">
      <h1 id="articles-heading" class="mb-6 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        Articles
      </h1>
      
      <section class="flex flex-col gap-5" aria-label="Search and filters">
        <SearchInput value={query} placeholder="Search articles..." clearHref={clearHref} />
        <PopularTags posts={allPosts} />
      </section>
      
      <BlogPostList search={query} posts={recentPosts} />
      
      {recentPosts.length === 0 && (
        <p class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
          Belum ada artikel
        </p>
      )}
      
      {!query && allPosts.length > recentPosts.length && (
        <a
          href="/posts"
          class="mt-6 inline-flex min-h-[44px] items-center text-sm text-neutral-600 underline-offset-2 hover:underline dark:text-neutral-400"
          data-astro-prefetch="hover"
        >
          View all articles →
        </a>
      )}
    </section>
  </div>
</Layout>
