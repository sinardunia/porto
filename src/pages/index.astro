---
import Layout from "@/layouts/Layout.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import BlogListItem from "@/components/blog/BlogListItem.astro";
import Link from "@/components/shared/Link.astro";
import { createSupabaseClient } from "@/lib/supabase";
import { withTimeout } from "@/lib/security";
import type { BlogPostSummary } from "@/types/blog";

const getLatestPosts = async (): Promise<BlogPostSummary[]> => {
  try {
    const supabase = createSupabaseClient();
    const { data, error } = await withTimeout(
      supabase
        .from("blog_posts")
        .select("id, slug, title, excerpt, cover_image_url, cover_image_alt, created_at, updated_at, is_published")
        .eq("is_published", true)
        .order("created_at", { ascending: false })
        .limit(2),
      10000,
      "Latest blog posts fetch"
    );

    if (error) {
      console.warn("Unable to load latest blog posts:", error.message);
      return [];
    }

    return data ?? [];
  } catch (error) {
    console.warn(
      "Unable to load latest blog posts:",
      error instanceof Error ? error.message : "Unknown error"
    );
    return [];
  }
};

const latestPosts = await getLatestPosts();
---

<style>
/* Animasi opacity dioptimalkan via hardware acceleration memanfaatkan properti will-change */
.fade-in {
  opacity: 0;
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  will-change: opacity;
}
@keyframes fadeIn {
  to { opacity: 1; }
}

.reveal {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  will-change: opacity, transform;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>

<script>
  function initHomeAnimations() {
    const mainElement = document.querySelector("main");
    const revealElements = document.querySelectorAll(".reveal");
    
    // Konfigurasi observer dengan threshold yang aman untuk mobile device layar pendek
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    }, { rootMargin: "0px 0px -50px 0px" });

    mainElement?.classList.add("fade-in");
    revealElements.forEach((element) => observer.observe(element));

    // Bersihkan instansi memori observer saat berpindah halaman di ekosistem Astro
    document.addEventListener("astro:before-swap", () => observer.disconnect(), { once: true });
  }

  // Amankan siklus hidup rendering dari interupsi navigasi Astro View Transitions
  initHomeAnimations();
  document.addEventListener("astro:page-load", initHomeAnimations);
</script>

<Layout>
  <main class="mx-auto flex w-full max-w-[540px] flex-col gap-20 px-4 md:px-0 pb-24 box-border min-w-0 overflow-x-hidden">
    
    <article class="flex flex-col gap-8 reveal">
      
      <header>
        <h1 class="flex items-center gap-2 text-3xl font-bold text-neutral-900 dark:text-neutral-100 transition-colors duration-200">
          <img 
            src="/star.gif" 
            alt="star" 
            width="24" 
            height="24" 
            class="w-6 h-6 object-contain pointer-events-none" 
          />
          Fuji 
          <span class="text-sm font-normal text-neutral-500 dark:text-neutral-400 ml-1 select-none">
            /<span class="font-bold underline tracking-wide">Waltahh</span>
          </span>
        </h1>
      </header>

      <div class="space-y-5 text-sm leading-7 text-neutral-700 dark:text-neutral-300">
        <p>Halo, saya Fuji.</p>

        <div class="space-y-4">
          <p>
            Tempat ini semacam arsip kecil buat menaruh cerita, duka,
            dan keseharian seada-adanya.
          </p>

          <p>
            Di luar itu, saya manusia yang menghabiskan waktu
            dengan bermain internet, menonton anime, olahraga,
            dan hal-hal lainnya :3
          </p>
        </div>

        <p class="font-medium">Senang Anda mampir :)</p>
      </div>
      
      <SocialLinks />
    </article>

    <article class="flex flex-col gap-8 reveal">
      <header class="flex w-full justify-between items-center gap-2">
        <h3 class="text-base font-semibold text-neutral-900 dark:text-neutral-100">Latest posts</h3>
        <Link href="/blog" label="See all posts" isUnderline target="_self" class="text-xs transition-all duration-200 hover:opacity-80" />
      </header>
      
      {latestPosts.length === 0 && (
        <p class="text-xs text-neutral-400 dark:text-neutral-500 italic">Soon, stay connected 👀...</p>
      )}
      
      <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 w-full min-w-0">
        {latestPosts.length !== 0 &&
          latestPosts.map((post) => (
            <div class="flex flex-col w-full min-w-0 reveal">
              <BlogListItem post={post} basePath="/blog" />
            </div>
          ))}
      </section>
    </article>

    <article class="flex flex-col gap-8 reveal">
      <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-6">
        📩 Email me at <Link href="mailto:fujihalimrabani1601@gmail.com" label="fujihalimrabani1601@gmail.com" class="font-medium text-neutral-800 dark:text-neutral-200 hover:underline transition-colors" />
      </p>
    </article>

  </main>
</Layout>