---
import Layout from "@/layouts/Layout.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import BlogListItem from "@/components/blog/BlogListItem.astro";
import Link from "@/components/shared/Link.astro";
import { createSupabaseClient } from "@/lib/supabase";
import { withTimeout } from "@/lib/security";
import type { BlogPostSummary } from "@/types/blog";

const getLatestPosts = async (): Promise<BlogPostSummary[]> => {
  try {
    const supabase = createSupabaseClient();
    const { data, error } = await withTimeout(
      supabase
        .from("blog_posts")
        .select("id, slug, title, excerpt, cover_image_url, cover_image_alt, created_at, updated_at, is_published")
        .eq("is_published", true)
        .order("created_at", { ascending: false })
        .limit(2),
      10000,
      "Latest blog posts fetch"
    );

    if (error) {
      console.warn("Unable to load latest blog posts:", error.message);
      return [];
    }

    return data ?? [];
  } catch (error) {
    console.warn(
      "Unable to load latest blog posts:",
      error instanceof Error ? error.message : "Unknown error"
    );
    return [];
  }
};

const latestPosts = await getLatestPosts();
---

<style>
.fade-in {
  opacity: 0;
  animation: fadeIn 0.8s ease-out forwards;
}
@keyframes fadeIn {
  to {
    opacity: 1;
  }
}

.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const mainElement = document.querySelector("main");
    const revealElements = document.querySelectorAll(".reveal");
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    });

    mainElement?.classList.add("fade-in");
    revealElements.forEach((element) => observer.observe(element));
  });
</script>

<Layout>
  <main class="flex flex-col gap-20 fade-in">
    <article class="flex flex-col gap-8 reveal">
      <!-- ada suara klik, loh -->
      <button >
        <h1 class="flex items-center gap-2 text-4xl font-bold dark:text-#e5e7eb">
          <img src="/star.gif" alt="star" class="w-6 h-6 animate-spin-slow" />
          Fuji 
          <span class="text-sm font-normal opacity-75 ml-1">
            /<span class="bold underline">Waltahh</span>
          </span>
        </h1>
      </button>
      <div class="space-y-5 leading-8 text-neutral-700">

  <p>Halo, saya Fuji.</p>

  <div class="space-y-4">
    <p>
      Tempat ini semacam arsip kecil buat menaruh cerita, duka,
      dan keseharian seada-adanya.
    </p>

    <p>
      Di luar itu, saya cuma orang biasa yang menghabiskan waktu
      dengan bermain internet, menonton anime, olahraga,
      dan hal-hal kecil lainnya :3
    </p>
  </div>

  <p>Senang Anda mampir.</p>

</div>
      
      <SocialLinks />
    </article>
    <article class="flex flex-col gap-8 reveal">
      <header class="flex w-full justify-between gap-2">
        <h3 class="text-lg font-medium text-text-light dark:text-neutral-100">Latest posts</h3>
        <Link href="/blog" label="See all posts" isUnderline target="_self" class="transition-transform hover:scale-105" />
      </header>
      {latestPosts.length === 0 && (
        <p class="text-muted-light dark:text-neutral-400">Soon, stay connected 👀...</p>
      )}
      <section class="flex flex-col gap-4 md:flex-row md:flex-wrap">
        {latestPosts.length !== 0 &&
          latestPosts.map((post) => (
            <div class="flex flex-col md:flex-row md:max-w-[500px] gap-4 reveal">
              <BlogListItem post={post} basePath="/blog" />
            </div>
          ))}
      </section>
    </article>
    <article class="flex flex-col gap-8 reveal">
      <p class="text-text-light dark:text-neutral-400">
        📩 Email me at <Link href="mailto:fujihalimrabani1601@gmail.com" label="fujihalimrabani1601@gmail.com" class="transition-colors hover:text-blue-500" />
      </p>
    </article>
  </main>
</Layout>