---
import Layout from "@/layouts/Layout.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import BlogListItem from "@/components/blog/BlogListItem.astro";
import Link from "@/components/shared/Link.astro";
import { createSupabaseClient } from "@/lib/supabase";
import { withTimeout } from "@/lib/security";
import type { BlogPostSummary } from "@/types/blog";

const getLatestPosts = async (): Promise<BlogPostSummary[]> => {
  try {
    const supabase = createSupabaseClient();

    const { data, error } = await withTimeout(
      supabase
        .from("blog_posts")
        .select(`
          id,
          slug,
          title,
          excerpt,
          cover_image_url,
          cover_image_alt,
          created_at,
          updated_at,
          is_published
        `)
        .eq("is_published", true)
        .order("created_at", { ascending: false })
        .limit(2),
      10000,
      "Latest blog posts fetch"
    );

    if (error) {
      console.warn("Unable to load latest blog posts:", error.message);
      return [];
    }

    return data ?? [];
  } catch (error) {
    console.warn(
      "Unable to load latest blog posts:",
      error instanceof Error ? error.message : "Unknown error"
    );

    return [];
  }
};

const latestPosts = await getLatestPosts();
---
<Layout>
  <main
    class="mx-auto flex w-full max-w-[720px] flex-col gap-14 px-5 pb-28 pt-6 md:px-0"
  >
    <section class="flex flex-col gap-6">
      <h1
        class="flex items-center gap-2 text-[32px] font-bold tracking-tight text-neutral-900 dark:text-neutral-100"
      >
        <img
          src="/star.gif"
          alt=""
          width="20"
          height="20"
          class="pointer-events-none h-5 w-5 object-contain"
        />

        Fuji

        <span
          class="select-none text-sm font-normal text-neutral-400 dark:text-neutral-500"
        >
          / Waltahh
        </span>
      </h1>

      <div
        class="space-y-4 text-[15px] leading-8 text-neutral-700 dark:text-neutral-300"
      >
        <p>Halo, saya Fuji.</p>

        <p>Saya kadang nulis di sini.</p>

        <p>
          Kadang serius.<br />
          Kadang nggak penting juga :)
        </p>
      </div>

      <SocialLinks />
    </section>

    <section class="flex flex-col gap-5">
      <div class="flex items-center justify-between">
        <span
          class="text-xs text-neutral-400 dark:text-neutral-500"
        >
          Recent things
        </span>

        <Link
          href="/blog"
          label="View all"
          isUnderline
          target="_self"
          class="text-xs text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200"
        />
      </div>

      {latestPosts.length === 0 ? (
        <p class="text-sm text-neutral-400 dark:text-neutral-500">
          Nothing here yet.
        </p>
      ) : (
        <div class="flex flex-col gap-4">
          {latestPosts.map((post) => (
            <BlogListItem
              post={post}
              basePath="/blog"
            />
          ))}
        </div>
      )}
    </section>
  </main>
</Layout>