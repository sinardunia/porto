---
import Layout from "@/layouts/Layout.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import BlogListItem from "@/components/blog/BlogListItem.astro";
import Link from "@/components/shared/Link.astro";
import AsciiPortrait from "@/components/home/AsciiPortrait.astro";
import { getPublishedBlogPosts } from "@/lib/blog";

const latestPosts = await getPublishedBlogPosts(2);

// Cache response at Vercel Edge Network
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, stale-while-revalidate=600"
);
---
<Layout description="A quiet personal archive of thoughts, writing, and experiments">
  <main
    class="mx-auto flex w-full max-w-[44rem] flex-col gap-14 px-5 pb-28 pt-6 min-w-0 overflow-x-hidden box-border md:px-0"
  >
    <section class="flex flex-col gap-6">
      <h1
        class="flex items-center gap-2 text-[32px] font-bold tracking-tight text-neutral-900 dark:text-neutral-100"
      >
        <img
          src="/star.gif"
          alt=""
          width="20"
          height="20"
          class="pointer-events-none h-5 w-5 object-contain"
        />

        Fuji
        <AsciiPortrait variant="inline" />

        <span
          class="select-none text-sm font-normal text-neutral-400 dark:text-neutral-500"
        >
          / Waltahh
        </span>
      </h1>

      <div class="flex flex-col lg:flex-row lg:gap-8 lg:items-start">
        <div
          class="space-y-4 text-[15px] leading-8 text-neutral-700 dark:text-neutral-300 lg:flex-1"
        >
          <p>Halo, saya Fuji.</p>

          <p>Saya kadang nulis di sini.</p>

          <p>
            Kadang serius.<br />
            Kadang tidak terlalu serius :)
          </p>
        </div>

        <AsciiPortrait variant="side" />
      </div>

      <SocialLinks />
    </section>

    <section class="flex flex-col gap-5">
      <div class="flex items-center justify-between">
        <span
          class="text-xs text-neutral-400 dark:text-neutral-500"
        >
          Latest writing
        </span>

        <Link
          href="/blog"
          label="View all"
          isUnderline
          target="_self"
          class="text-xs text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200"
        />
      </div>

      {latestPosts.length === 0 ? (
        <p class="text-sm text-neutral-400 dark:text-neutral-500">
          Nothing here yet.
        </p>
      ) : (
        <div class="flex flex-col gap-4">
          {latestPosts.map((post) => (
            <BlogListItem
              post={post}
              basePath="/blog"
            />
          ))}
        </div>
      )}
    </section>
  </main>
</Layout>