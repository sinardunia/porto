---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import PopularTags from "@/components/blog/PopularTags.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import Pagination from "@/components/blog/Pagination.astro";
import { getPublishedBlogPostSummaries, collectTagCounts } from "@/lib/blog";
import { tagToSlug } from "@/lib/tags";
import type { BlogPostSummary } from "@/types/blog";
import { SITE_URL } from "@/data/config";
import { AUTHOR } from "@/data/author";

export const prerender = false;

const legacyTag = Astro.url.searchParams.get("tag")?.trim();
if (legacyTag) {
  return Astro.redirect(`/tags/${tagToSlug(legacyTag)}`, 301);
}

const query = Astro.url.searchParams.get("q")?.trim() || "";
const clearHref = "/";

const POSTS_PER_PAGE = 10;

let currentPage = 1;
const pageParam = Astro.url.searchParams.get("page");
if (pageParam && /^\d+$/.test(pageParam)) {
  currentPage = parseInt(pageParam, 10);
  if (currentPage < 1) currentPage = 1;
}

let allPosts: BlogPostSummary[] = [];
try {
  allPosts = await getPublishedBlogPostSummaries();
} catch {
  allPosts = [];
}

const allTagCounts = collectTagCounts(allPosts);
const allTagNames = allTagCounts.map((t) => t.name);

if (query) {
  const matchedTag = allTagCounts.find((t) => t.name.toLowerCase() === query.toLowerCase());
  if (matchedTag) {
    return Astro.redirect(`/tags/${matchedTag.slug}`, 302);
  }
}

const nonAIPosts = allPosts.filter((post) => !post.aiGenerated);

let filteredPosts = nonAIPosts;
if (query) {
  const lowerQuery = query.toLowerCase();
  filteredPosts = nonAIPosts.filter(
    (post) =>
      post.title.toLowerCase().includes(lowerQuery) ||
      (post.description && post.description.toLowerCase().includes(lowerQuery)) ||
      (post.tags && post.tags.some((tag) => tag.toLowerCase().includes(lowerQuery)))
  );
}

const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
if (totalPages === 0) currentPage = 1;

const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const displayPosts = filteredPosts.slice(startIndex, startIndex + POSTS_PER_PAGE);

Astro.response.headers.set(
  "Cache-Control",
  query
    ? "public, max-age=30, stale-while-revalidate=300"
    : "public, max-age=60, stale-while-revalidate=600"
);

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Blog",
  description: "Arsip pribadi yang tenang tentang pemikiran, tulisan, dan eksperimen.",
  url: SITE_URL,
  publisher: {
    "@type": "Person",
    name: AUTHOR.name,
    alternateName: AUTHOR.pseudonym,
    url: SITE_URL,
  },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${SITE_URL}/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
  inLanguage: "id",
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Artikel", item: SITE_URL },
  ],
};

const jsonLd = [websiteJsonLd, breadcrumbJsonLd];
const pageTitle = query ? `Hasil pencarian: ${query}` : "Artikel";
const pageDescription = query
  ? `Artikel yang mengandung kata "${query}"`
  : "Catatan yang kebetulan ditulis. Jika bermanfaat, alhamdulillah.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
  tagNames={allTagNames}
>
  <div class="flex w-full min-w-0 flex-col pb-12">
    <div class="hidden sm:block">
      <SearchInput value={query} placeholder="Cari tag... (python, belajar, anime)" clearHref={clearHref} tagData={allTagCounts} />
      <div class="mt-3">
        <PopularTags posts={allPosts} />
      </div>
    </div>

    <div class="sm:hidden">
      <PopularTags posts={allPosts} />
    </div>

    {totalPosts === 0 ? (
      <p class="mt-8 text-sm text-neutral-600 dark:text-neutral-400">
        {query ? "Tidak ada artikel yang cocok dengan pencarian." : "Belum ada artikel."}
      </p>
    ) : (
      <>
        <BlogPostList posts={displayPosts} />
        <Pagination currentPage={currentPage} totalPages={totalPages} searchQuery={query} />
      </>
    )}
  </div>
</Layout>
