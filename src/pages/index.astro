---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";

export const prerender = false;

const query = Astro.url.searchParams.get("q")?.trim() || "";
const activeTag = Astro.url.searchParams.get("tag")?.trim() || "";

const hiddenInputs: { name: string; value: string }[] = [];
if (activeTag) hiddenInputs.push({ name: "tag", value: activeTag });

const clearHref = activeTag ? `/?tag=${encodeURIComponent(activeTag)}` : "/";

// Cache: lebih pendek kalau ada filter aktif
Astro.response.headers.set(
  "Cache-Control",
  query || activeTag
    ? "public, max-age=30, stale-while-revalidate=300"
    : "public, max-age=60, stale-while-revalidate=600"
);
---

<Layout
  title={activeTag ? `${activeTag} — Blog` : "Blog"}
  description={activeTag ? `Tulisan yang ditandai dengan "${activeTag}".` : "Catatan keresahan yang kebetulan ditulis. Jika bermanfaat, alhamdulillah."}
>
  <main class="flex w-full flex-col gap-6 pt-2 pb-32 min-w-0 min-h-[70vh]">
    <header class="w-full min-w-0">
      <h1 class="text-xs font-medium tracking-wide text-neutral-400 dark:text-neutral-500">
        {activeTag ? `Tag: ${activeTag}` : "Blog"}
      </h1>
      {!activeTag && (
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
          Catatan keresahan yang kebetulan ditulis.
        </p>
      )}
      {activeTag && (
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
          Tulisan yang ditandai dengan "{activeTag}".
        </p>
      )}
    </header>

    <SearchInput
      action="/"
      value={query}
      placeholder="Cari tulisan..."
      clearHref={query ? clearHref : undefined}
      hiddenInputs={hiddenInputs}
    />

    <BlogPostList search={query} tag={activeTag} />
  </main>
</Layout>