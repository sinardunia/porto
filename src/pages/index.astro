---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import PopularTags from "@/components/blog/PopularTags.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import AuthorCard from "@/components/author/AuthorCard.astro";
import SiteMascot from "@/components/author/SiteMascot.astro";
import { getPublishedBlogPostSummaries } from "@/lib/blog";
import { tagToSlug } from "@/lib/tags";
import type { BlogPostSummary } from "@/types/blog";
import { SITE_URL } from "@/data/config";
import { AUTHOR } from "@/data/author";

export const prerender = false;

const legacyTag = Astro.url.searchParams.get("tag")?.trim();
if (legacyTag) {
  return Astro.redirect(`/tags/${tagToSlug(legacyTag)}`, 301);
}

const query = Astro.url.searchParams.get("q")?.trim() || "";
const clearHref = "/";

let allPosts: BlogPostSummary[] = [];
try {
  allPosts = await getPublishedBlogPostSummaries();
} catch {
  allPosts = [];
}

Astro.response.headers.set(
  "Cache-Control",
  query
    ? "public, max-age=30, stale-while-revalidate=300"
    : "public, max-age=60, stale-while-revalidate=600"
);

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Porto",
  description: "A quiet personal archive of thoughts, writing, and experiments.",
  url: SITE_URL,
  publisher: {
    "@type": "Person",
    name: AUTHOR.name,
    url: SITE_URL,
  },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${SITE_URL}/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
  inLanguage: "id",
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Articles", item: SITE_URL },
  ],
};

const jsonLd = [websiteJsonLd, breadcrumbJsonLd];
const pageTitle = "Articles";
const pageDescription = "Catatan keresahan yang kebetulan ditulis. Jika bermanfaat, alhamdulillah.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={["blog", "personal", "writing", "essays"]}
  jsonLd={jsonLd}
>
  <div class="flex w-full min-w-0 flex-col gap-8 pb-24">
    <section
      class="relative flex items-start justify-between gap-4 rounded-lg border border-neutral-200/60 bg-white/40 px-4 py-4 dark:border-neutral-800/60 dark:bg-neutral-900/20 sm:px-5"
      aria-label="About this blog"
    >
      <div class="min-w-0 flex-1">
        <AuthorCard variant="compact" />
        <a
          href="/about"
          class="mt-2 inline-flex min-h-[44px] items-center text-xs text-neutral-500 underline-offset-2 hover:text-neutral-700 hover:underline dark:hover:text-neutral-300"
          data-astro-prefetch="hover"
        >
          Read more
        </a>
      </div>
      <SiteMascot variant="inline" class="absolute right-3 top-2 sm:relative sm:right-0 sm:top-0" />
    </section>

    <section class="flex flex-col gap-5" aria-label="Search and filters">
      <SearchInput value={query} placeholder="Search articles..." clearHref={clearHref} />
      <PopularTags posts={allPosts} />
    </section>

    <section aria-labelledby="articles-heading">
      <h1 id="articles-heading" class="mb-6 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        Articles
      </h1>
      <BlogPostList search={query} />
    </section>
  </div>
</Layout>
