---
import Layout from "@/layouts/Layout.astro";
import { createSupabaseAdminClient } from "@/lib/supabase";
import { withTimeout } from "@/lib/security";

export const prerender = false;

const adminSecret = Astro.cookies.get("admin_secret")?.value;
const expectedSecret = import.meta.env.THOUGHTS_ADMIN_SECRET;

if (!adminSecret || adminSecret !== expectedSecret) {
  return Astro.redirect("/admin/login");
}

const supabase = createSupabaseAdminClient();

const { data: thoughtsData, error: thoughtsError } = await withTimeout(
  supabase
    .from("thoughts")
    .select("id, content, yt_link, created_at")
    .order("created_at", { ascending: false })
    .limit(50),
  5000,
  "Thoughts list"
);

const thoughts = thoughtsError ? [] : (thoughtsData ?? []);
---

<Layout title="Thoughts Admin" noindex={true}>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <header class="flex items-center justify-between">
      <div class="flex flex-col gap-2">
        <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">
          Thoughts
        </h1>
        <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
          Kelola thoughts singkat Anda.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="/admin/thoughts/new"
          class="inline-flex items-center gap-2 rounded-lg bg-neutral-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-neutral-300"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Tulis Baru
        </a>
        <a
          href="/admin/dashboard"
          class="text-xs text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors"
        >
          ← Dashboard
        </a>
      </div>
    </header>

    <!-- LIST -->
    <section class="flex flex-col gap-3">
      <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500">
        Semua Thoughts ({thoughts.length})
      </h2>

      <p id="status-message" class="min-h-6 text-sm text-neutral-500 dark:text-neutral-400" aria-live="polite"></p>

      {thoughts.length === 0 ? (
        <p class="text-sm text-neutral-400 dark:text-neutral-500">Belum ada thoughts.</p>
      ) : (
        <ul class="flex flex-col gap-2" id="thoughts-list">
          {thoughts.map((t) => (
            <li
              class="thought-row flex items-start justify-between gap-3 rounded-lg border border-neutral-100 dark:border-neutral-800 p-3"
              data-id={t.id}
            >
              <div class="min-w-0 flex-1">
                <p class="text-sm text-neutral-800 dark:text-neutral-200 truncate">
                  {t.content}
                </p>
                <div class="mt-1 flex items-center gap-2 text-[11px] text-neutral-400 dark:text-neutral-500">
                  <time>{new Date(t.created_at).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" })}</time>
                  {t.yt_link && <span class="text-orange-500 font-semibold text-[10px]">YT</span>}
                </div>
              </div>
              <div class="flex items-center gap-1.5 shrink-0">
                <a
                  href={`/admin/thoughts/edit?id=${t.id}`}
                  class="rounded-md border border-neutral-200 px-2.5 py-1 text-xs text-neutral-500 transition-colors hover:border-neutral-400 hover:text-neutral-800 dark:border-neutral-800 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:text-neutral-200"
                >
                  Edit
                </a>
                <button
                  type="button"
                  class="thought-delete-btn rounded-md border border-red-200 px-2.5 py-1 text-xs text-red-500 transition-colors hover:border-red-400 hover:text-red-700 dark:border-red-900/30 dark:text-red-400 dark:hover:border-red-700 dark:hover:text-red-300"
                  data-id={t.id}
                >
                  Hapus
                </button>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
</Layout>

<script is:inline>
  (function() {
    const statusEl = document.getElementById("status-message");

    const setStatus = (msg) => {
      if (statusEl) statusEl.textContent = msg;
    };

    /* Delete buttons */
    document.querySelectorAll(".thought-delete-btn").forEach((btn) => {
      btn.addEventListener("click", async function() {
        const id = btn.dataset.id || "";
        if (!id || !confirm("Hapus thought ini? Tindakan tidak bisa dibatalkan.")) return;

        const adminSecret = localStorage.getItem("thoughts_admin_secret");
        if (!adminSecret) {
          setStatus("Error: Admin secret tidak ditemukan di localStorage. Harap login kembali.");
          return;
        }

        setStatus("Menghapus...");
        try {
          const res = await fetch("/api/thoughts?id=" + encodeURIComponent(id), {
            method: "DELETE",
            headers: { Authorization: "Bearer " + adminSecret },
          });
          const data = await res.json().catch(() => null);

          if (!res.ok) throw new Error((data && data.message) || ("HTTP " + res.status));

          const row = btn.closest(".thought-row");
          if (row) row.remove();
          setStatus("Thought berhasil dihapus.");
          setTimeout(() => setStatus(""), 3000);
        } catch (err) {
          const msg = err instanceof Error ? err.message : String(err);
          setStatus("Error hapus: " + msg);
        }
      });
    });
  })();
</script>