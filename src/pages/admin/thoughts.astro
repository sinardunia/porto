---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;
---

<Layout title="Post Thought - Fuji Halim Rabani">
  <main class="mx-auto flex w-full max-w-prose flex-col gap-8">
    <header class="flex flex-col gap-2">
      <h1 class="text-2xl font-bold text-text-light dark:text-neutral-100">
        New thought
      </h1>
      <p class="text-sm leading-7 text-muted-light dark:text-neutral-400">
        Tulis singkat saja. Simpan momen sebelum lewat.
      </p>
    </header>

<form id="thought-form" novalidate class="flex flex-col gap-5">
      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Admin secret</span>
        <input
          id="admin-secret"
          name="adminSecret"
          type="password"
          autocomplete="current-password"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-text-light outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
          required
        />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Thought</span>
        <textarea
          name="content"
          rows="8"
          placeholder="Apa yang ingin disimpan hari ini?"
          class="min-h-48 resize-y rounded-lg border border-border-light bg-secondary-light px-4 py-3 leading-7 text-text-light outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
          required
        ></textarea>
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Image, optional</span>
        <input
          name="image"
          type="file"
          accept="image/*"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-sm text-muted-light file:mr-4 file:rounded-md file:border-0 file:bg-neutral-200 file:px-3 file:py-2 file:text-sm file:text-neutral-900 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:file:bg-neutral-800 dark:file:text-neutral-100"
        />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Image alt text, optional</span>
        <input
          name="imageAlt"
          type="text"
          placeholder="Deskripsi singkat gambar"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-text-light outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <button
        id="publish-button"
        type="button"
        class="rounded-lg bg-text-light px-5 py-3 text-sm font-medium text-primary-light transition-colors hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-neutral-300"
      >
        Publish
      </button>

      <p id="form-status" class="min-h-6 text-sm text-muted-light dark:text-neutral-400" aria-live="polite"></p>
    </form>
  </main>
</Layout>
<script type="module">
  const form = document.querySelector("#thought-form");
  const status = document.querySelector("#form-status");
  const secretInput = document.querySelector("#admin-secret");
  const publishButton = document.querySelector("#publish-button");

  if (
    !(form instanceof HTMLFormElement) ||
    !(secretInput instanceof HTMLInputElement) ||
    !(publishButton instanceof HTMLButtonElement)
  ) {
    console.error("Thought form elements missing.");
  } else {
    secretInput.value =
      localStorage.getItem("thoughts_admin_secret") || "";

    const draftKey = "thought_admin_draft";

    const contentInput =
      form.elements.namedItem("content");

    const imageAltInput =
      form.elements.namedItem("imageAlt");

    const restoreDraft = () => {
      try {
        const draft = JSON.parse(
          localStorage.getItem(draftKey) || "{}"
        );

        if (
          contentInput instanceof HTMLTextAreaElement &&
          typeof draft.content === "string"
        ) {
          contentInput.value = draft.content;
        }

        if (
          imageAltInput instanceof HTMLInputElement &&
          typeof draft.imageAlt === "string"
        ) {
          imageAltInput.value = draft.imageAlt;
        }
      } catch {}
    };

    const saveDraft = () => {
      localStorage.setItem(
        draftKey,
        JSON.stringify({
          content:
            contentInput instanceof HTMLTextAreaElement
              ? contentInput.value
              : "",
          imageAlt:
            imageAltInput instanceof HTMLInputElement
              ? imageAltInput.value
              : "",
        })
      );
    };

    restoreDraft();

    form.addEventListener("input", saveDraft);

    const setLoading = (loading) => {
      publishButton.disabled = loading;
      publishButton.textContent = loading
        ? "Publishing..."
        : "Publish";
    };

    const setStatus = (message) => {
      if (status) status.textContent = message;
    };

    const submitThought = async () => {
      const adminSecret = secretInput.value.trim();

      if (!adminSecret) {
        setStatus("Admin secret belum diisi.");
        return;
      }

      localStorage.setItem(
        "thoughts_admin_secret",
        adminSecret
      );

      const formData = new FormData(form);

      setLoading(true);
      setStatus("");

      try {
        const response = await fetch("/api/thoughts", {
        method: "POST",
        credentials: "same-origin",
        headers: {
          Authorization: `Bearer ${adminSecret}`,
        },
        body: formData,
      });

        const result = await response
          .json()
          .catch(() => null);

        if (!response.ok) {
          throw new Error(
            result?.message ||
              "Failed to publish thought."
          );
        }

        form.reset();

        localStorage.removeItem(draftKey);

        secretInput.value = adminSecret;

        setStatus(
          result?.message ||
            "Thought published successfully."
        );
      } catch (error) {
        setStatus(
          error instanceof Error
            ? error.message
            : "Failed to publish thought."
        );
      } finally {
        setLoading(false);
      }
    };

    form.addEventListener(
      "submit",
      async (event) => {
        event.preventDefault();
        event.stopPropagation();
        await submitThought();
      }
    );

    publishButton.addEventListener(
      "click",
      async (event) => {
        event.preventDefault();
        event.stopPropagation();
        await submitThought();
      }
    );
  }
</script>