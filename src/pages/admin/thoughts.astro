---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;
---

<Layout title="Post Thought - Fuji Halim Rabani">
  <main class="mx-auto flex w-full max-w-prose flex-col gap-8">
    <header class="flex flex-col gap-2">
      <h1 class="text-2xl font-bold text-text-light dark:text-neutral-100">
        New thought
      </h1>
      <p class="text-sm leading-7 text-muted-light dark:text-neutral-400">
        Tulis singkat saja. Simpan momen sebelum lewat.
      </p>
    </header>

    <form id="thought-form" novalidate class="flex flex-col gap-5">
      <!-- ADMIN SECRET -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Admin secret</span>
        <input
          id="admin-secret"
          name="adminSecret"
          type="password"
          autocomplete="current-password"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-text-light outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
          required
        />
      </label>

      <!-- CONTENT -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Thought</span>
        <textarea
          name="content"
          rows="8"
          placeholder="Apa yang ingin disimpan hari ini?"
          class="min-h-48 resize-y rounded-lg border border-border-light bg-secondary-light px-4 py-3 leading-7 text-text-light outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
          required
        ></textarea>
      </label>

      <!-- MEDIA UPLOAD -->
      <div class="flex flex-col gap-3">
        <label
          for="media-input"
          class="flex cursor-pointer flex-col items-center justify-center gap-2 rounded-lg border border-dashed border-border-light bg-secondary-light px-6 py-10 text-center"
        >
          <span class="text-sm text-muted-light">Upload images / videos</span>
          <span class="text-xs text-muted-light">max 6 files</span>
        </label>

        <input
          id="media-input"
          name="media"
          type="file"
          accept="image/*,video/*"
          multiple
          class="hidden"
        />

        <!-- PREVIEW -->
        <div id="media-preview" class="grid grid-cols-2 gap-2 sm:grid-cols-3"></div>
      </div>

      <!-- ALT -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-muted-light dark:text-neutral-400">Media alt text</span>
        <input
          name="imageAlt"
          type="text"
          placeholder="Deskripsi singkat"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-text-light outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <!-- BUTTON -->
      <button
        id="publish-button"
        type="button"
        class="rounded-lg bg-text-light px-5 py-3 text-sm font-medium text-primary-light"
      >
        Publish
      </button>

      <p id="form-status" class="min-h-6 text-sm text-muted-light"></p>
    </form>
  </main>
</Layout>

<script type="module">
  const form = document.querySelector("#thought-form");
  const status = document.querySelector("#form-status");
  const secretInput = document.querySelector("#admin-secret");
  const publishButton = document.querySelector("#publish-button");
  const mediaInput = document.querySelector("#media-input");
  const mediaPreview = document.querySelector("#media-preview");

  let selectedFiles = [];
  const MAX_FILES = 6;

  if (
    !(form instanceof HTMLFormElement) ||
    !(secretInput instanceof HTMLInputElement) ||
    !(publishButton instanceof HTMLButtonElement) ||
    !(mediaInput instanceof HTMLInputElement)
  ) {
    console.error("Missing elements");
  } else {
    secretInput.value = localStorage.getItem("thoughts_admin_secret") || "";

    const setStatus = (msg) => {
      if (status) status.textContent = msg;
    };

    const setLoading = (loading) => {
      publishButton.disabled = loading;
      publishButton.textContent = loading ? "Publishing..." : "Publish";
    };

    const renderPreview = (files) => {
      if (!mediaPreview) return;

      mediaPreview.innerHTML = "";

      files.slice(0, MAX_FILES).forEach((file) => {
        const url = URL.createObjectURL(file);

        const wrapper = document.createElement("div");
        wrapper.className =
          "overflow-hidden rounded-lg border border-border-light bg-neutral-100";

        if (file.type.startsWith("image/")) {
          const img = document.createElement("img");
          img.src = url;
          img.className = "h-28 w-full object-cover";
          wrapper.appendChild(img);
        } else if (file.type.startsWith("video/")) {
          const video = document.createElement("video");
          video.src = url;
          video.controls = true;
          video.className = "h-28 w-full object-cover";
          wrapper.appendChild(video);
        }

        mediaPreview.appendChild(wrapper);
      });
    };

    mediaInput.addEventListener("change", () => {
      if (!mediaInput.files) return;

      selectedFiles = Array.from(mediaInput.files).slice(0, MAX_FILES);
      renderPreview(selectedFiles);
    });

    const submitThought = async () => {
      const adminSecret = secretInput.value.trim();

      if (!adminSecret) {
        setStatus("Admin secret required");
        return;
      }

      const formData = new FormData();

      formData.append("adminSecret", adminSecret);
      formData.append(
        "content",
        form.elements.namedItem("content").value
      );

      selectedFiles.forEach((file) => {
        formData.append("media", file);
      });

      const alt = form.elements.namedItem("imageAlt")?.value;
      if (alt) formData.append("imageAlt", alt);

      try {
        setLoading(true);
        setStatus("");

        const res = await fetch("/api/thoughts", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${adminSecret}`,
          },
          body: formData,
        });

        const data = await res.json().catch(() => null);

        if (!res.ok) {
          throw new Error(data?.message || "Failed");
        }

        form.reset();
        selectedFiles = [];
        if (mediaPreview) mediaPreview.innerHTML = "";

        setStatus("Published!");
      } catch (err) {
        setStatus(err.message || "Error");
      } finally {
        setLoading(false);
      }
    };

    publishButton.addEventListener("click", submitThought);
  }
</script>