---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;
---

<Layout title="Write Blog Post" noindex={true}>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <header class="flex flex-col gap-2">
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100">
        New blog post
      </h1>
      <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
        Tempat menulis yang lebih panjang. Tidak perlu rapi sekaligus.
      </p>
    </header>

    <form id="blog-form" novalidate class="flex flex-col gap-5">
      <!-- ADMIN SECRET -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Admin secret</span>
        <input
          id="admin-secret"
          type="password"
          autocomplete="current-password"
          required
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <!-- TITLE -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Title</span>
        <input
          id="blog-title"
          name="title"
          type="text"
          required
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <!-- SLUG -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Slug</span>
        <input
          id="blog-slug"
          name="slug"
          type="text"
          required
          placeholder="contoh-tulisan-panjang"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <!-- EXCERPT -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Excerpt (optional)</span>
        <textarea
          name="excerpt"
          rows="3"
          maxlength="500"
          class="resize-y rounded-lg border border-border-light bg-secondary-light px-4 py-3 leading-7 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        ></textarea>
      </label>

      <!-- TAGS -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Tags (comma separated)</span>
        <input
          name="tags"
          type="text"
          placeholder="tech, personal, opinion"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <!-- EDITOR -->
      <div class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Content</span>

        <!-- TOOLBAR -->
        <div class="flex flex-wrap gap-1 rounded-t-lg border border-b-0 border-border-light bg-neutral-50 px-2 py-2 dark:border-neutral-800 dark:bg-neutral-900">
          <button type="button" data-md="bold" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Bold">Bold</button>
          <button type="button" data-md="italic" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Italic">Italic</button>
          <button type="button" data-md="heading" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Heading">H2</button>
          <button type="button" data-md="link" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Link">Link</button>
          <button type="button" data-md="quote" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Quote">Quote</button>
          <button type="button" data-md="code" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Code">Code</button>
          <button type="button" data-md="ul" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Bullet list">List</button>
          <button type="button" data-md="ol" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="Numbered list">1.</button>
          <button type="button" data-md="youtube" class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-800" title="YouTube embed">YT</button>
        </div>

        <textarea
          id="blog-content"
          name="content"
          rows="16"
          required
          placeholder="# Judul&#10;&#10;Tulis pelan-pelan di sini..."
          class="min-h-[20rem] resize-y rounded-b-lg rounded-t-none border border-border-light bg-secondary-light px-4 py-3 font-mono text-sm leading-7 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        ></textarea>

        <!-- PREVIEW TOGGLE -->
        <button type="button" id="preview-toggle" class="self-start text-xs text-neutral-400 hover:text-neutral-700 dark:text-neutral-500 dark:hover:text-neutral-300">
          Show preview
        </button>

        <!-- LIVE PREVIEW -->
        <div id="preview-panel" class="hidden rounded-lg border border-border-light bg-white p-5 text-sm leading-7 text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-200">
          <p class="text-xs text-neutral-400 dark:text-neutral-500 mb-3">Preview</p>
          <div id="preview-content" class="prose prose-neutral max-w-none dark:prose-invert"></div>
        </div>
      </div>

      <!-- COVER IMAGE -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Cover image (optional)</span>
        <input
          name="coverImage"
          type="file"
          accept="image/jpeg,image/png,image/webp"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-sm text-neutral-600 outline-none file:mr-4 file:rounded-md file:border-0 file:bg-neutral-900 file:px-3 file:py-2 file:text-sm file:text-white focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300 dark:file:bg-neutral-100 dark:file:text-neutral-950"
        />
      </label>

      <!-- COVER ALT -->
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Cover image alt (optional)</span>
        <input
          name="coverImageAlt"
          type="text"
          placeholder="Deskripsi singkat gambar"
          class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </label>

      <!-- SUBMIT -->
      <button
        id="publish-button"
        type="button"
        class="flex items-center justify-center gap-2 rounded-lg bg-neutral-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-neutral-300 disabled:opacity-60 disabled:cursor-not-allowed"
      >
        <span id="btn-text">Save blog post</span>
        <span id="btn-spinner" class="hidden h-4 w-4 animate-spin rounded-full border-2 border-white/30 border-t-white dark:border-neutral-400/30 dark:border-t-neutral-950"></span>
      </button>

      <p id="form-status" class="min-h-6 text-sm text-neutral-500 dark:text-neutral-400" aria-live="polite"></p>
    </form>
  </main>
</Layout>

<style is:global>
  .youtube-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #0a0a0a;
    margin: 1rem 0;
  }
  .youtube-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .youtube-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    cursor: pointer;
  }
  .youtube-placeholder::before {
    content: '';
    width: 0;
    height: 0;
    border-left: 20px solid rgba(255, 255, 255, 0.9);
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
    margin-left: 4px;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const placeholder = (e.target as HTMLElement).closest('.youtube-placeholder');
    if (!placeholder) return;
    const embed = placeholder.closest('.youtube-embed');
    if (!embed) return;
    const id = embed.getAttribute('data-id');
    if (!id) return;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&autoplay=1`;
    iframe.title = 'YouTube video player';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.allowFullscreen = true;
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
    placeholder.replaceWith(iframe);
  });
</script>

<script type="module">
  const form = document.querySelector("#blog-form");
  const status = document.querySelector("#form-status");
  const secretInput = document.querySelector("#admin-secret");
  const titleInput = document.querySelector("#blog-title");
  const slugInput = document.querySelector("#blog-slug");
  const contentInput = document.querySelector("#blog-content");
  const publishButton = document.querySelector("#publish-button");
  const btnText = document.querySelector("#btn-text");
  const btnSpinner = document.querySelector("#btn-spinner");
  const previewToggle = document.querySelector("#preview-toggle");
  const previewPanel = document.querySelector("#preview-panel");
  const previewContent = document.querySelector("#preview-content");

  if (
    !(form instanceof HTMLFormElement) ||
    !(secretInput instanceof HTMLInputElement) ||
    !(titleInput instanceof HTMLInputElement) ||
    !(slugInput instanceof HTMLInputElement) ||
    !(contentInput instanceof HTMLTextAreaElement) ||
    !(publishButton instanceof HTMLButtonElement)
  ) {
    console.error("Blog admin form elements missing.");
  } else {
    secretInput.value = localStorage.getItem("thoughts_admin_secret") || "";

    /* -------------------------
       SLUG AUTO-GENERATE
    -------------------------- */
    const slugify = (text) =>
      text
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-")
        .replace(/^-|-$/g, "")
        .slice(0, 120);

    titleInput.addEventListener("blur", () => {
      if (!slugInput.value.trim()) {
        slugInput.value = slugify(titleInput.value);
      }
    });

    /* -------------------------
       MARKDOWN TOOLBAR
    -------------------------- */
    const insertAtCursor = (before, after = "") => {
      contentInput.focus();
      const start = contentInput.selectionStart;
      const end = contentInput.selectionEnd;
      const text = contentInput.value;
      const selected = text.slice(start, end);
      const replacement = before + selected + after;

      contentInput.setRangeText(replacement, start, end, "end");
      contentInput.setSelectionRange(start + before.length, start + before.length + selected.length);
      contentInput.dispatchEvent(new Event("input"));
    };

    const toolbarActions = {
      bold: () => insertAtCursor("**", "**"),
      italic: () => insertAtCursor("*", "*"),
      heading: () => insertAtCursor("## ", ""),
      link: () => insertAtCursor("[", "](url)"),
      quote: () => insertAtCursor("> ", ""),
      code: () => insertAtCursor("```\n", "\n```"),
      ul: () => insertAtCursor("- ", ""),
      ol: () => insertAtCursor("1. ", ""),
      youtube: () => {
        const url = prompt("Paste YouTube link:");
        if (!url) return;
        insertAtCursor("\n" + url.trim() + "\n", "");
      },
    };

    document.querySelectorAll("[data-md]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const key = btn.getAttribute("data-md");
        if (key && toolbarActions[key]) toolbarActions[key]();
      });
    });

    /* -------------------------
       AUTO-CONTINUE LIST ON ENTER
    -------------------------- */
    contentInput.addEventListener("keydown", (e) => {
      if (e.key !== "Enter") return;

      const start = contentInput.selectionStart;
      const text = contentInput.value;
      const lineStart = text.lastIndexOf("\n", start - 1) + 1;
      const line = text.slice(lineStart, start);

      const bulletMatch = line.match(/^(-|\*|\+)\s/);
      const numberMatch = line.match(/^(\d+)\.\s/);

      if (!bulletMatch && !numberMatch) return;

      const prefix = bulletMatch ? bulletMatch[0] : numberMatch[0];
      const body = line.slice(prefix.length).trim();

      // If line is empty except prefix, remove prefix (user wants to exit list)
      if (!body) {
        e.preventDefault();
        const before = text.slice(0, lineStart);
        const after = text.slice(start);
        contentInput.value = before + after;
        contentInput.setSelectionRange(lineStart, lineStart);
        contentInput.dispatchEvent(new Event("input"));
        return;
      }

      e.preventDefault();
      const nextPrefix = bulletMatch
        ? prefix
        : String(Number(numberMatch[1]) + 1) + ". ";
      const before = text.slice(0, start);
      const after = text.slice(start);
      contentInput.value = before + "\n" + nextPrefix + after;
      const newCursor = start + 1 + nextPrefix.length;
      contentInput.setSelectionRange(newCursor, newCursor);
      contentInput.dispatchEvent(new Event("input"));
    });

    /* -------------------------
       LIVE PREVIEW
    -------------------------- */

    const convertYouTubeLinks = (html) => {
      const patterns = [
        /(?:https?:\/\/)?(?:www\.)?youtube\.com\/watch\?v=([a-zA-Z0-9_-]{11})/,
        /(?:https?:\/\/)?(?:www\.)?youtu\.be\/([a-zA-Z0-9_-]{11})/,
        /(?:https?:\/\/)?(?:www\.)?youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/,
      ];
      const extractId = (url) => {
        for (const p of patterns) {
          const m = url.match(p);
          if (m) return m[1];
        }
        return null;
      };
      return html.replace(
        /<a\s+href="([^"]+)"[^>]*>([^<]*)<\/a>/g,
        (match, href, text) => {
          const id = extractId(href);
          if (!id || text.trim() !== href.trim()) return match;
          return `<div class="youtube-embed" data-id="${id}"><div class="youtube-placeholder"></div></div>`;
        }
      );
    };

    const mdToHtml = (md) => {
      const esc = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const inline = (s) => esc(s)
        .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`(.+?)`/g, '<code>$1</code>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');

      const lines = md.split('\n');
      const out = [];
      let code = [], inCode = false;
      let list = [], listType = '';

      const flush = () => {
        if (code.length) { out.push(`<pre><code>${esc(code.join('\n'))}</code></pre>`); code = []; inCode = false; }
        if (list.length) { out.push(`<${listType}>${list.join('')}</${listType}>`); list = []; listType = ''; }
      };

      for (const raw of lines) {
        const line = raw.trimEnd();
        if (line.startsWith('```')) { flush(); inCode = !inCode; continue; }
        if (inCode) { code.push(line); continue; }

        const b = line.match(/^([-*+]) (.+)$/);
        const n = line.match(/^(\d+)\. (.+)$/);
        if (b) {
          if (listType !== 'ul') flush();
          listType = 'ul'; list.push(`<li>${inline(b[2])}</li>`);
          continue;
        }
        if (n) {
          if (listType !== 'ol') flush();
          listType = 'ol'; list.push(`<li>${inline(n[2])}</li>`);
          continue;
        }

        flush();
        if (!line) continue;
        if (line.startsWith('### ')) { out.push(`<h3>${inline(line.slice(4))}</h3>`); continue; }
        if (line.startsWith('## ')) { out.push(`<h2>${inline(line.slice(3))}</h2>`); continue; }
        if (line.startsWith('# ')) { out.push(`<h1>${inline(line.slice(2))}</h1>`); continue; }
        if (line.startsWith('> ')) { out.push(`<blockquote>${inline(line.slice(2))}</blockquote>`); continue; }
        out.push(`<p>${inline(line)}</p>`);
      }
      flush();
      return out.join('\n');
    };

    const updatePreview = () => {
      if (!previewContent) return;
      const html = mdToHtml(contentInput.value);
      previewContent.innerHTML = convertYouTubeLinks(html || "") || "<p class=\"text-neutral-400 italic\">Tidak ada konten untuk dipreview.</p>";
    };

    contentInput.addEventListener("input", updatePreview);

    if (previewToggle && previewPanel) {
      previewToggle.addEventListener("click", () => {
        const isHidden = previewPanel.classList.contains("hidden");
        previewPanel.classList.toggle("hidden", !isHidden);
        previewToggle.textContent = isHidden ? "Hide preview" : "Show preview";
        if (isHidden) updatePreview();
      });
    }

    /* -------------------------
       SUBMIT
    -------------------------- */
    const setLoading = (loading) => {
      publishButton.disabled = loading;
      if (btnText) btnText.textContent = loading ? "Saving..." : "Save blog post";
      if (btnSpinner) btnSpinner.classList.toggle("hidden", !loading);
    };

    const setStatus = (message) => {
      if (status) status.textContent = message;
    };

    const submitBlogPost = async () => {
      const adminSecret = secretInput.value.trim();

      if (!adminSecret) {
        setStatus("Admin secret belum diisi.");
        return;
      }

      localStorage.setItem("thoughts_admin_secret", adminSecret);

      const formData = new FormData(form);

      setLoading(true);
      setStatus("");

      try {
        const response = await fetch("/api/blog", {
          method: "POST",
          credentials: "same-origin",
          headers: {
            Authorization: `Bearer ${adminSecret}`,
          },
          body: formData,
        });

        const result = await response.json().catch(() => null);

        if (!response.ok) {
          throw new Error(result?.message || "Failed to save blog post.");
        }

        form.reset();
        secretInput.value = adminSecret;
        if (previewContent) previewContent.innerHTML = "";

        setStatus(result?.message || "Blog post published successfully.");
      } catch (error) {
        setStatus(
          error instanceof Error
            ? error.message
            : "Failed to save blog post."
        );
      } finally {
        setLoading(false);
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      event.stopPropagation();
      await submitBlogPost();
    });

    publishButton.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();
      await submitBlogPost();
    });
  }
</script>
