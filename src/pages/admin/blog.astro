---
import Layout from "@/layouts/Layout.astro";
import { createSupabaseAdminClient } from "@/lib/supabase";
import { withTimeout } from "@/lib/security";

export const prerender = false;

const adminSecret = Astro.cookies.get("admin_secret")?.value;
const expectedSecret = import.meta.env.THOUGHTS_ADMIN_SECRET;

if (!adminSecret || adminSecret !== expectedSecret) {
  return Astro.redirect("/admin/login");
}

const supabase = createSupabaseAdminClient();

const { data: postsData, error: postsError } = await withTimeout(
  supabase
    .from("blog_posts")
    .select("id, slug, title, excerpt, content, cover_image_url, cover_image_alt, tags, created_at, is_published")
    .order("created_at", { ascending: false })
    .limit(50),
  5000,
  "Blog posts list"
);

const posts = postsError ? [] : (postsData ?? []);
---

<Layout title="Blog Admin" noindex={true}>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <header class="flex items-center justify-between">
      <div class="flex flex-col gap-2">
        <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">
          Blog
        </h1>
        <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
          Kelola tulisan panjang Anda.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="/admin/blog/new"
          class="inline-flex items-center gap-2 rounded-xl bg-neutral-900 text-white px-4 py-2 text-sm font-semibold transition-all hover:bg-neutral-800 dark:bg-white dark:text-neutral-900 dark:hover:bg-neutral-100 shadow-md active:scale-95"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Tulis Baru
        </a>
        <a
          href="/admin/dashboard"
          class="text-xs font-semibold text-neutral-500 hover:text-indigo-600 dark:text-neutral-400 dark:hover:text-indigo-400 transition-colors"
        >
          ← Dashboard
        </a>
      </div>
    </header>

    <!-- LIST -->
    <section class="flex flex-col gap-3">
      <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500">
        Semua Posts ({posts.length})
      </h2>

      <p id="status-message" class="min-h-6 text-sm text-neutral-500 dark:text-neutral-400" aria-live="polite"></p>

      {posts.length === 0 ? (
        <p class="text-sm text-neutral-400 dark:text-neutral-500">Belum ada blog posts.</p>
      ) : (
        <ul class="flex flex-col gap-3" id="blog-list">
          {posts.map((p) => (
            <li
              class="blog-row flex items-center justify-between gap-3 rounded-xl border border-neutral-200/40 bg-white/30 dark:bg-white/[0.01] dark:border-white/5 p-4 hover:bg-white/50 dark:hover:bg-white/[0.03] transition-all"
              data-slug={p.slug}
            >
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 truncate">
                  {p.title}
                </p>
                <div class="mt-1 flex items-center gap-2 text-[11px] text-neutral-400 dark:text-neutral-500">
                  <time>{new Date(p.created_at).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" })}</time>
                  {p.is_published ? (
                    <span class="rounded-full bg-green-100/80 px-2 py-0.5 text-[10px] text-green-700 font-semibold dark:bg-green-950/40 dark:text-green-400">Published</span>
                  ) : (
                    <span class="rounded-full bg-neutral-100/80 px-2 py-0.5 text-[10px] text-neutral-600 font-semibold dark:bg-neutral-800/40 dark:text-neutral-400">Draft</span>
                  )}
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <a
                  href={`/admin/blog/edit?slug=${p.slug}`}
                  class="rounded-lg border border-neutral-200/60 bg-white/50 dark:bg-white/[0.02] dark:border-white/5 px-3 py-1.5 text-xs text-neutral-600 dark:text-neutral-400 transition-all hover:bg-white/80 dark:hover:bg-white/[0.05] hover:border-neutral-300 dark:hover:border-white/15"
                >
                  Edit
                </a>
                <button
                  type="button"
                  class="blog-delete-btn rounded-lg border border-red-200/60 bg-red-500/5 dark:bg-red-500/10 dark:border-red-500/10 px-3 py-1.5 text-xs text-red-500 transition-all hover:bg-red-500/10 dark:hover:bg-red-500/20 dark:hover:text-red-400"
                  data-slug={p.slug}
                >
                  Hapus
                </button>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
</Layout>

<script is:inline>
  (function() {
    const statusEl = document.getElementById("status-message");

    const setStatus = (msg) => {
      if (statusEl) statusEl.textContent = msg;
    };

    /* Delete buttons */
    document.querySelectorAll(".blog-delete-btn").forEach((btn) => {
      btn.addEventListener("click", async function() {
        const slug = btn.dataset.slug || "";
        if (!slug || !confirm("Hapus blog post ini? Tindakan tidak bisa dibatalkan.")) return;

        setStatus("Menghapus...");
        try {
          const res = await fetch("/api/blog?slug=" + encodeURIComponent(slug), {
            method: "DELETE",
            credentials: "same-origin",
          });
          const data = await res.json().catch(() => null);

          if (res.status === 401) {
            window.location.href = "/admin/login";
            return;
          }

          if (!res.ok) throw new Error((data && data.message) || ("HTTP " + res.status));

          const row = btn.closest(".blog-row");
          if (row) row.remove();
          setStatus("Blog post berhasil dihapus.");
          setTimeout(() => setStatus(""), 3000);
        } catch (err) {
          setStatus("Error hapus: " + (err instanceof Error ? err.message : String(err)));
        }
      });
    });
  })();
</script>
