---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;
---

<Layout title="Write Blog Post - Fuji Halim Rabani">
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <header class="flex flex-col gap-2">
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100">
        New blog post
      </h1>
      <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
        Tempat menulis yang lebih panjang. Tidak perlu rapi sekaligus.
      </p>
    </header>

  <form id="blog-form" novalidate class="flex flex-col gap-5">
      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Admin secret</span>
        <input id="admin-secret" type="password" autocomplete="current-password" required class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Title</span>
        <input name="title" type="text" required class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Slug</span>
        <input name="slug" type="text" required placeholder="contoh-tulisan-panjang" class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Excerpt, optional</span>
        <textarea name="excerpt" rows="3" class="resize-y rounded-lg border border-border-light bg-secondary-light px-4 py-3 leading-7 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"></textarea>
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Content, Markdown</span>
        <textarea name="content" rows="18" required placeholder="# Judul\n\nTulis pelan-pelan di sini." class="min-h-[24rem] resize-y rounded-lg border border-border-light bg-secondary-light px-4 py-3 font-mono text-sm leading-7 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100"></textarea>
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Cover image, optional</span>
        <input name="coverImage" type="file" accept="image/jpeg,image/png,image/webp" class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-sm text-neutral-600 outline-none file:mr-4 file:rounded-md file:border-0 file:bg-neutral-900 file:px-3 file:py-2 file:text-sm file:text-white focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300 dark:file:bg-neutral-100 dark:file:text-neutral-950" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Cover image alt, optional</span>
        <input name="coverImageAlt" type="text" placeholder="Deskripsi singkat gambar" class="rounded-lg border border-border-light bg-secondary-light px-4 py-3 text-neutral-900 outline-none focus:border-accent-light dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100" />
      </label>

      <label class="flex items-center gap-3 text-sm text-neutral-600 dark:text-neutral-400">
        <input name="isPublished" type="checkbox" class="h-4 w-4" />
        Publish now
      </label>

      <button id="publish-button" type="button" class="rounded-lg bg-neutral-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-neutral-300">
        Save blog post
      </button>

      <p id="form-status" class="min-h-6 text-sm text-neutral-500 dark:text-neutral-400" aria-live="polite"></p>
    </form>
  </main>
</Layout>

<script type="module">
  const form = document.querySelector("#blog-form");
  const status = document.querySelector("#form-status");
  const secretInput = document.querySelector("#admin-secret");
  const publishButton = document.querySelector("#publish-button");

  if (
    !(form instanceof HTMLFormElement) ||
    !(secretInput instanceof HTMLInputElement) ||
    !(publishButton instanceof HTMLButtonElement)
  ) {
    console.error("Blog admin form elements missing.");
  } else {
    secretInput.value =
      localStorage.getItem("thoughts_admin_secret") || "";

    const setLoading = (loading) => {
      publishButton.disabled = loading;
      publishButton.textContent = loading
        ? "Saving..."
        : "Save blog post";
    };

    const setStatus = (message) => {
      if (status) status.textContent = message;
    };

    const submitBlogPost = async () => {
      const adminSecret = secretInput.value.trim();

      if (!adminSecret) {
        setStatus("Admin secret belum diisi.");
        return;
      }

      localStorage.setItem(
        "thoughts_admin_secret",
        adminSecret
      );

      const formData = new FormData(form);

      setLoading(true);
      setStatus("");

      try {
        const response = await fetch("/api/blog", {
          method: "POST",
          credentials: "same-origin",
          headers: {
            Authorization: `Bearer ${adminSecret}`,
          },
          body: formData,
        });

        const result = await response.json().catch(() => null);

        if (!response.ok) {
          throw new Error(
            result?.message || "Failed to save blog post."
          );
        }

        form.reset();
        secretInput.value = adminSecret;

        setStatus(
          result?.message ||
            "Blog post published successfully."
        );
      } catch (error) {
        setStatus(
          error instanceof Error
            ? error.message
            : "Failed to save blog post."
        );
      } finally {
        setLoading(false);
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      event.stopPropagation();
      await submitBlogPost();
    });

    publishButton.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();
      await submitBlogPost();
    });
  }
</script>