---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;

const adminSecret = Astro.cookies.get("admin_secret")?.value;
const expectedSecret = import.meta.env.THOUGHTS_ADMIN_SECRET;

if (!adminSecret || adminSecret !== expectedSecret) {
  return Astro.redirect("/admin/login");
}
---

<Layout title="Tulis Thought Baru" noindex={true}>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <header class="flex items-center justify-between">
      <div class="flex flex-col gap-2">
        <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">
          Tulis Thought Baru
        </h1>
        <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
          Tulis singkat saja. Simpan momen sebelum lewat.
        </p>
      </div>
      <a
        href="/admin/thoughts"
        class="text-xs text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors"
      >
        ← Batal & Kembali
      </a>
    </header>

    <form id="thought-form" novalidate class="flex flex-col gap-5 pt-4">
      <!-- CONTENT -->
      <label class="flex flex-col gap-2">
        <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Thought</span>
        <textarea
          id="thought-content"
          name="content"
          rows="6"
          placeholder="Apa yang ingin disimpan hari ini?"
          class="min-h-32 resize-y rounded-lg border border-neutral-200 bg-white px-4 py-3 leading-7 text-neutral-900 outline-none focus:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100 dark:focus:border-neutral-600"
          required
        ></textarea>
      </label>

      <!-- YOUTUBE LINK -->
      <label class="flex flex-col gap-2">
        <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300">YouTube link (opsional)</span>
        <input
          id="yt-link"
          name="ytLink"
          type="url"
          placeholder="https://youtube.com/watch?v=..."
          class="rounded-lg border border-neutral-200 bg-white px-4 py-3 text-neutral-900 outline-none focus:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100 dark:focus:border-neutral-600"
        />
        <span class="text-[10px] text-neutral-400 dark:text-neutral-500">Embed 1 video YouTube saja. Tidak bisa digabung dengan media upload.</span>
      </label>

      <!-- MEDIA UPLOAD -->
      <div class="flex flex-col gap-3">
        <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Upload Media (opsional)</span>
        <label
          for="media-input"
          class="flex cursor-pointer flex-col items-center justify-center gap-2 rounded-lg border border-dashed border-neutral-200 bg-white hover:bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:bg-neutral-900/50 px-6 py-8 text-center"
        >
          <span class="text-sm text-neutral-500 dark:text-neutral-400">Pilih gambar / video / GIF</span>
          <span class="text-xs text-neutral-400 dark:text-neutral-500">Maksimal 6 file</span>
        </label>

        <input
          id="media-input"
          name="media"
          type="file"
          accept="image/*,video/*"
          multiple
          class="hidden"
        />

        <!-- PREVIEW -->
        <div id="media-preview" class="grid grid-cols-2 gap-2 sm:grid-cols-3"></div>
      </div>

      <!-- ALT -->
      <label class="flex flex-col gap-2">
        <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Media alt text</span>
        <input
          id="image-alt"
          name="imageAlt"
          type="text"
          placeholder="Deskripsi singkat gambar untuk aksesibilitas"
          class="rounded-lg border border-neutral-200 bg-white px-4 py-3 text-neutral-900 outline-none focus:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100 dark:focus:border-neutral-600"
        />
      </label>

      <!-- BUTTONS -->
      <div class="flex items-center gap-3">
        <button
          id="publish-button"
          type="button"
          class="rounded-lg bg-neutral-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200 disabled:opacity-50"
        >
          Publish
        </button>
        <a
          href="/admin/thoughts"
          class="rounded-lg border border-neutral-200 px-5 py-3 text-sm font-medium text-neutral-600 transition-colors hover:border-neutral-400 hover:text-neutral-800 dark:border-neutral-800 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:text-neutral-200"
        >
          Batal
        </a>
      </div>

      <!-- COMPRESSION PROGRESS -->
      <div id="compression-ui" class="hidden flex-col gap-2 rounded-lg border border-neutral-100 bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 p-4">
        <div class="flex items-center justify-between">
          <span id="compression-label" class="text-xs font-medium text-neutral-500 dark:text-neutral-400">Mengompresi...</span>
          <span id="compression-percent" class="text-xs font-bold text-neutral-800 dark:text-neutral-200">0%</span>
        </div>
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-neutral-200 dark:bg-neutral-700">
          <div id="compression-bar" class="h-full w-0 rounded-full bg-neutral-800 dark:bg-neutral-200 transition-all duration-300"></div>
        </div>
      </div>

      <p id="form-status" class="min-h-6 text-sm text-neutral-500 dark:text-neutral-400" aria-live="polite"></p>
    </form>
  </main>
</Layout>

<script is:inline>
  (function() {
    const form = document.getElementById("thought-form");
    const status = document.getElementById("form-status");
    const publishButton = document.getElementById("publish-button");
    const mediaInput = document.getElementById("media-input");
    const mediaPreview = document.getElementById("media-preview");
    const compressionUi = document.getElementById("compression-ui");
    const compressionLabel = document.getElementById("compression-label");
    const compressionPercent = document.getElementById("compression-percent");
    const compressionBar = document.getElementById("compression-bar");

    if (!form || !publishButton) return;

    let selectedFiles = [];
    let previewUrls = [];
    const MAX_FILES = 6;

    const setStatus = (msg) => {
      if (status) status.textContent = msg;
    };

    const setLoading = (loading) => {
      publishButton.disabled = loading;
      publishButton.textContent = loading ? "Publishing..." : "Publish";
    };

    const setCompressing = (show, label, percent) => {
      if (compressionUi) {
        compressionUi.classList.toggle("hidden", !show);
        compressionUi.classList.toggle("flex", show);
      }
      if (compressionLabel) compressionLabel.textContent = label || "";
      if (compressionPercent) compressionPercent.textContent = (percent || 0) + "%";
      if (compressionBar) compressionBar.style.width = (percent || 0) + "%";
    };

    const renderPreview = (files) => {
      if (!mediaPreview) return;
      previewUrls.forEach((url) => URL.revokeObjectURL(url));
      previewUrls = [];
      mediaPreview.innerHTML = "";
      files.slice(0, MAX_FILES).forEach((file) => {
        const url = URL.createObjectURL(file);
        previewUrls.push(url);
        const wrapper = document.createElement("div");
        wrapper.className = "overflow-hidden rounded-lg border border-neutral-100 dark:border-neutral-800 bg-neutral-100 dark:bg-neutral-900";
        if (file.type.startsWith("image/")) {
          const img = document.createElement("img");
          img.src = url;
          img.className = "h-28 w-full object-cover";
          wrapper.appendChild(img);
        } else if (file.type.startsWith("video/")) {
          const video = document.createElement("video");
          video.src = url;
          video.controls = true;
          video.className = "h-28 w-full object-cover";
          wrapper.appendChild(video);
        }
        mediaPreview.appendChild(wrapper);
      });
    };

    if (mediaInput) {
      mediaInput.addEventListener("change", () => {
        if (!mediaInput.files) return;
        selectedFiles = Array.from(mediaInput.files).slice(0, MAX_FILES);
        renderPreview(selectedFiles);
      });
    }

    const extractYouTubeId = (url) => {
      const patterns = [
        /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/v\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/,
        /^([a-zA-Z0-9_-]{11})$/,
      ];
      for (const p of patterns) {
        const m = url.match(p);
        if (m) return m[1];
      }
      return null;
    };

    const compressMediaFallback = async (files, onItemProgress) => {
      try {
        const mod = await import("/src/lib/compression.ts");
        if (mod && typeof mod.compressMedia === "function") {
          return await mod.compressMedia(files, onItemProgress);
        }
      } catch (e) {
        console.warn("[THOUGHTS] Compression module failed:", e);
      }
      return files.map((f) => ({ file: f, originalSize: f.size, compressedSize: f.size }));
    };

    const submitThought = async () => {
      try {
        const adminSecret = localStorage.getItem("thoughts_admin_secret");
        if (!adminSecret) {
          setStatus("Error: Admin secret tidak ditemukan. Silakan login ulang.");
          return;
        }

        const ytInput = document.getElementById("yt-link");
        const ytLink = ytInput && ytInput.value ? ytInput.value.trim() : "";
        const hasMedia = selectedFiles.length > 0;

        if (ytLink && hasMedia) {
          setStatus("Pilih salah satu: YouTube link atau media upload.");
          return;
        }

        if (ytLink) {
          const ytId = extractYouTubeId(ytLink);
          if (!ytId) {
            setStatus("URL YouTube tidak valid.");
            return;
          }
        }

        const contentEl = document.getElementById("thought-content");
        const content = contentEl && contentEl.value ? contentEl.value.trim() : "";
        if (!content) {
          setStatus("Thought content is required.");
          return;
        }

        setLoading(true);
        setStatus("Mengirim ke server...");

        const formData = new FormData();
        formData.append("adminSecret", adminSecret);
        formData.append("content", content);
        if (ytLink) formData.append("ytLink", ytLink);

        const altEl = document.getElementById("image-alt");
        const alt = altEl && altEl.value ? altEl.value.trim() : "";
        if (alt) formData.append("imageAlt", alt);

        let filesToUpload = selectedFiles;

        if (hasMedia) {
          setCompressing(true, "Mengompresi media...", 0);
          try {
            const results = await compressMediaFallback(selectedFiles, (index, percent) => {
              const fileName = selectedFiles[index]?.name || "";
              setCompressing(true, "Mengompresi " + fileName + "...", percent);
            });
            filesToUpload = results.map((r) => r.file);
          } catch (err) {
            console.error("Compression failed:", err);
          } finally {
            setCompressing(false);
          }
        }

        filesToUpload.forEach((file) => {
          formData.append("media", file);
        });

        const res = await fetch("/api/thoughts", {
          method: "POST",
          headers: {
            Authorization: "Bearer " + adminSecret,
          },
          body: formData,
        });

        const data = await res.json().catch(() => null);

        if (!res.ok) {
          throw new Error((data && data.message) || ("HTTP " + res.status));
        }

        setStatus("Thought published successfully.");
        setTimeout(() => window.location.href = "/admin/thoughts", 1000);
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        setStatus("Error: " + msg);
        setLoading(false);
      }
    };

    publishButton.addEventListener("click", submitThought);
  })();
</script>
