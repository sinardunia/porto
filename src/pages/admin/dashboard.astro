---
import Layout from "@/layouts/Layout.astro";
import { createSupabaseAdminClient } from "@/lib/supabase";
import { withTimeout } from "@/lib/security";

export const prerender = false;

const adminSecret = Astro.cookies.get("admin_secret")?.value;
const expectedSecret = import.meta.env.THOUGHTS_ADMIN_SECRET;

if (!adminSecret || adminSecret !== expectedSecret) {
  return Astro.redirect("/admin/login");
}

const supabase = createSupabaseAdminClient();

const blogRes = await withTimeout(
  supabase
    .from("blog_posts")
    .select("id, slug, title, created_at, is_published")
    .order("created_at", { ascending: false })
    .limit(5),
  5000,
  "Recent blog posts"
);

const blogPosts = blogRes.error ? [] : (blogRes.data ?? []);
const blogCount = blogRes.error ? 0 : blogPosts.length;
---

<Layout title="Admin Dashboard" noindex={true}>
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
    <header class="flex flex-col gap-2">
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100">
        Dashboard
      </h1>
      <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
        Kelola blog posts.
      </p>
    </header>

    <!-- Card -->
    <a
      href="/admin/blog"
      class="group rounded-lg border border-neutral-200 dark:border-neutral-800 p-5 transition-colors hover:bg-neutral-50 dark:hover:bg-neutral-900 max-w-xs"
    >
      <div class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500">
        Blog Posts
      </div>
      <div class="mt-2 text-3xl font-semibold text-neutral-900 dark:text-neutral-100">
        {blogCount}
      </div>
      <div class="mt-1 text-xs text-neutral-400 dark:text-neutral-500">
        {blogCount === 1 ? "post" : "posts"}
      </div>
      <div class="mt-3 text-xs font-medium text-neutral-500 group-hover:text-neutral-800 dark:text-neutral-400 dark:group-hover:text-neutral-200 transition-colors">
        Kelola →
      </div>
    </a>

    <!-- Quick Actions -->
    <div class="flex flex-wrap gap-3">
      <a
        href="/admin/blog/new"
        class="inline-flex items-center gap-2 rounded-lg bg-neutral-900 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-neutral-300"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        New Blog Post
      </a>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-lg border border-neutral-200 px-4 py-2.5 text-sm font-medium text-neutral-700 transition-colors hover:border-neutral-400 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-neutral-600"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        View Blog
      </a>
    </div>

    <!-- Recent Blog Posts -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500">
          Blog Terbaru
        </h2>
        <a href="/admin/blog" class="text-xs text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors">
          Lihat semua
        </a>
      </div>
      {blogPosts.length === 0 ? (
        <p class="text-sm text-neutral-400 dark:text-neutral-500">Belum ada blog posts.</p>
      ) : (
        <ul class="flex flex-col gap-3">
          {blogPosts.map((p) => (
            <li class="flex items-start justify-between gap-4 rounded-lg border border-neutral-100 dark:border-neutral-800 p-3">
              <div class="min-w-0 flex-1">
                <p class="text-sm text-neutral-800 dark:text-neutral-200 truncate">
                  {p.title}
                </p>
                <div class="mt-1 flex items-center gap-2 text-[11px] text-neutral-400 dark:text-neutral-500">
                  <span>{new Date(p.created_at).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" })}</span>
                  {p.is_published ? (
                    <span class="rounded-full bg-green-100 px-1.5 py-0.5 text-[10px] text-green-700 dark:bg-green-900/30 dark:text-green-400">Published</span>
                  ) : (
                    <span class="rounded-full bg-neutral-100 px-1.5 py-0.5 text-[10px] text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400">Draft</span>
                  )}
                </div>
              </div>
              <a
                href={`/admin/blog/edit?slug=${p.slug}`}
                class="shrink-0 rounded-md border border-neutral-200 px-2.5 py-1 text-xs text-neutral-500 transition-colors hover:border-neutral-400 hover:text-neutral-800 dark:border-neutral-800 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:text-neutral-200"
              >
                Edit
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
</Layout>
