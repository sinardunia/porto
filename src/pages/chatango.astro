---
import Layout from "@/layouts/Layout.astro";

const cboxUrl = "https://www5.cbox.ws/box/?boxid=963154&boxtag=jT6w2F";
---

<Layout title="Chat" description="Chat">
  <main class="mx-auto flex w-full max-w-[44rem] flex-col gap-8 px-5 pb-24 pt-0 min-w-0 overflow-x-hidden box-border md:px-0">
    <header class="pt-10 pb-6 w-full min-w-0 overflow-hidden border-b border-neutral-100/50 dark:border-neutral-900/30">
      <div class="flex items-center gap-2">
        <h1 class="text-sm font-black uppercase tracking-[0.2em] text-neutral-800 dark:text-neutral-100">
          Chat
        </h1>
        <span class="h-1 w-1 rounded-full bg-orange-500 animate-pulse"></span>
      </div>
    </header>

    <div class="relative">
      <iframe
        id="chatFrame"
        src={cboxUrl}
        class="w-full h-[450px] rounded-lg"
        allowtransparency="yes"
        allow="autoplay"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        scrolling="auto"
        sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
      ></iframe>

      <button
        class="absolute top-3 right-3 bg-neutral-100 dark:bg-neutral-800 p-2 rounded-full transition-all hover:rotate-180 text-neutral-600 dark:text-neutral-300 shadow-sm"
        onclick="document.getElementById('chatFrame').src = document.getElementById('chatFrame').src"
        aria-label="Refresh chat"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
      </button>
    </div>
  </main>
</Layout>
