---
import { tagToSlug } from "@/lib/tags";

export const prerender = false;

const legacyTag = Astro.url.searchParams.get("tag")?.trim();
if (legacyTag) {
  return Astro.redirect(`/tags/${tagToSlug(legacyTag)}`, 301);
}

const query = Astro.url.searchParams.get("q")?.trim() || "";
const page = Astro.url.searchParams.get("page")?.trim() || "";

let redirectUrl = "/";
const params = new URLSearchParams();
if (query) params.set("q", query);
if (page && /^\d+$/.test(page) && parseInt(page, 10) > 1) params.set("page", page);
const qs = params.toString();
if (qs) redirectUrl += `?${qs}`;

return Astro.redirect(redirectUrl, 301);
---

<!-- Redirecting to homepage -->
