---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/shared/SearchInput.astro";
import PopularTags from "@/components/blog/PopularTags.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import { getPublishedBlogPostSummaries } from "@/lib/blog";
import { tagToSlug } from "@/lib/tags";
import type { BlogPostSummary } from "@/types/blog";
import { SITE_URL } from "@/data/config";
import { AUTHOR } from "@/data/author";

export const prerender = false;

const legacyTag = Astro.url.searchParams.get("tag")?.trim();
if (legacyTag) {
  return Astro.redirect(`/tags/${tagToSlug(legacyTag)}`, 301);
}

const query = Astro.url.searchParams.get("q")?.trim() || "";
const clearHref = "/posts";

let allPosts: BlogPostSummary[] = [];
try {
  allPosts = await getPublishedBlogPostSummaries();
} catch {
  allPosts = [];
}

Astro.response.headers.set(
  "Cache-Control",
  query
    ? "public, max-age=30, stale-while-revalidate=300"
    : "public, max-age=60, stale-while-revalidate=600"
);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Articles", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "All Articles", item: `${SITE_URL}/posts` },
  ],
};

const jsonLd = [breadcrumbJsonLd];
const pageTitle = "All Articles";
const pageDescription = "Semua catatan yang kebetulan ditulis.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={["blog", "personal", "writing", "essays", "archive"]}
  jsonLd={jsonLd}
>
  <div class="flex w-full min-w-0 flex-col gap-8 pb-24">
    <section class="flex flex-col gap-5" aria-label="Search and filters">
      <SearchInput value={query} placeholder="Search all articles..." clearHref={clearHref} />
      <PopularTags posts={allPosts} />
    </section>

    <section aria-labelledby="articles-heading">
      <h1 id="articles-heading" class="mb-6 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        All Articles
      </h1>
      <BlogPostList search={query} />
    </section>
  </div>
</Layout>
