---
import { marked } from "marked";
import Layout from "@/layouts/Layout.astro";
import { createSupabaseClient } from "@/lib/supabase";
import { sanitizeRenderedHtml, withTimeout } from "@/lib/security";
import type { BlogPost } from "@/types/blog";

export const prerender = false;

const { slug } = Astro.params;

const getBlogPost = async (): Promise<BlogPost | null> => {
  if (!slug) return null;

  try {
    const supabase = createSupabaseClient();
    const { data, error } = await withTimeout(
      supabase
        .from("blog_posts")
        .select("id, slug, title, excerpt, content, cover_image_url, cover_image_alt, created_at, updated_at, is_published")
        .eq("slug", slug)
        .eq("is_published", true)
        .single(),
      10000,
      "Blog post fetch"
    );

    if (error) {
      console.warn("Unable to load blog post:", error.message);
      return null;
    }

    return data;
  } catch (error) {
    console.warn(
      "Unable to load blog post:",
      error instanceof Error ? error.message : "Unknown error"
    );
    return null;
  }
};

const post = await getBlogPost();

if (!post) {
  Astro.response.status = 404;
}

const createdAt = post ? new Date(post.created_at) : null;
const formattedDate = createdAt && !Number.isNaN(createdAt.getTime())
  ? new Intl.DateTimeFormat("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    }).format(createdAt)
  : post?.created_at;
const renderedContent = post ? sanitizeRenderedHtml(await marked.parse(post.content)) : "";
---

<Layout title={post ? `${post.title} - Fuji Halim Rabani` : "Blog Post Not Found - Fuji Halim Rabani"}>
  {post ? (
    <main class="post mx-auto flex w-full max-w-[44rem] flex-col gap-8 pb-24">
      <header class="flex flex-col gap-4">
        <a href="/posts" class="text-sm text-neutral-500 hover:text-neutral-800 dark:text-neutral-500 dark:hover:text-neutral-300">
          ← Blog
        </a>

        <div class="flex flex-col gap-3">
          <h1 class="text-3xl font-semibold leading-tight tracking-tight text-neutral-900 dark:text-neutral-100">
            {post.title}
          </h1>

          {post.excerpt && (
            <p class="text-[0.98rem] leading-8 text-neutral-500 dark:text-neutral-400">
              {post.excerpt}
            </p>
          )}

          <time datetime={post.created_at} class="text-xs text-neutral-400 dark:text-neutral-600">
            {formattedDate}
          </time>
        </div>

        {post.cover_image_url && (
          <img
            src={post.cover_image_url}
            alt={post.cover_image_alt || ""}
            class="h-auto max-h-[520px] w-full rounded-xl object-contain opacity-95"
            loading="lazy"
            decoding="async"
          />
        )}
      </header>

      <article class="prose prose-slate max-w-none dark:prose-invert prose-p:leading-8 prose-p:text-neutral-700 dark:prose-p:text-neutral-300 prose-headings:font-semibold prose-headings:tracking-tight" set:html={renderedContent} />
    </main>
  ) : (
    <main class="mx-auto flex w-full max-w-[42rem] flex-col gap-4 pb-24">
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100">Blog post not found</h1>
      <p class="text-sm leading-7 text-neutral-500 dark:text-neutral-400">
        belum ada...
      </p>
      <a href="/posts" class="text-sm text-neutral-500 hover:text-neutral-800 dark:text-neutral-500 dark:hover:text-neutral-300">
        ← Back to blog
      </a>
    </main>
  )}
</Layout>
