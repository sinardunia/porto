---
import Layout from "../layouts/Layout.astro";

export const prerender = true;
---

<Layout title="Page not found" noindex={true}>
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 py-16 text-center">
    {/* Minimal 404 - clean and calm */}
    <div class="mb-6 text-6xl font-light text-neutral-300 dark:text-neutral-700 select-none">
      404
    </div>

    <h1 class="mb-3 text-lg font-medium text-neutral-800 dark:text-neutral-200">
      Page not found
    </h1>

    <p class="mb-8 max-w-xs text-sm text-neutral-500 dark:text-neutral-500 leading-relaxed">
      The page you're looking for doesn't exist or has been moved.
    </p>

    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-200 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to home
    </a>
  </main>
</Layout>
