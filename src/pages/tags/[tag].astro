---
import Layout from "@/layouts/Layout.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import {
  getAllPublishedBlogPostSummaries,
  collectTagCounts,
  filterPostsByTag,
  findTagBySlug,
} from "@/lib/blog";
import { SITE_URL } from "@/data/config";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getAllPublishedBlogPostSummaries();
  const tags = collectTagCounts(posts);
  return tags.map((tag) => ({
    params: { tag: tag.slug },
  }));
}

const { tag: tagSlug } = Astro.params;

if (!tagSlug || typeof tagSlug !== "string") {
  return Astro.redirect("/tags");
}

const allPosts = await getAllPublishedBlogPostSummaries();
const tagInfo = findTagBySlug(allPosts, tagSlug);
const posts = tagInfo ? filterPostsByTag(allPosts, tagSlug) : [];

if (!tagInfo) {
  Astro.response.status = 404;
}

const articleLabel = posts.length === 1 ? "article" : "articles";

const breadcrumbJsonLd = tagInfo
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Articles", item: SITE_URL },
        { "@type": "ListItem", position: 2, name: "Tags", item: `${SITE_URL}/tags` },
        {
          "@type": "ListItem",
          position: 3,
          name: tagInfo.name,
          item: `${SITE_URL}/tags/${tagInfo.slug}`,
        },
      ],
    }
  : undefined;
---

<Layout
  title={tagInfo ? tagInfo.name : "Tag not found"}
  description={tagInfo ? `${posts.length} ${articleLabel} tagged "${tagInfo.name}".` : "This tag does not exist."}
  noindex={!tagInfo}
  keywords={tagInfo ? [tagInfo.name, "blog", "articles"] : undefined}
  jsonLd={breadcrumbJsonLd ? [breadcrumbJsonLd] : undefined}
>
  <div class="mx-auto w-full max-w-[42rem] pb-24">
    {tagInfo ? (
      <>
        <header class="mb-10">
          <nav class="mb-6" aria-label="Breadcrumb">
            <a
              href="/tags"
              class="inline-flex min-h-[44px] items-center gap-1.5 text-sm text-neutral-500 transition-colors hover:text-neutral-800 dark:text-neutral-500 dark:hover:text-neutral-300"
              data-astro-prefetch="hover"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              Tags
            </a>
          </nav>
          <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
            {tagInfo.name}
          </h1>
          <p class="mt-2 text-sm tabular-nums text-neutral-500 dark:text-neutral-500">
            {posts.length} {articleLabel}
          </p>
        </header>

        <BlogPostList posts={posts} />
      </>
    ) : (
      <div class="py-16 text-center">
        <h1 class="mb-3 text-xl font-semibold text-neutral-900 dark:text-neutral-100">Tag not found</h1>
        <p class="mb-6 text-sm text-neutral-500 dark:text-neutral-400">No articles use this tag.</p>
        <a
          href="/tags"
          class="text-sm font-medium text-neutral-700 underline-offset-2 hover:underline dark:text-neutral-300"
        >
          Browse all tags
        </a>
      </div>
    )}
  </div>
</Layout>
