---
import Layout from "@/layouts/Layout.astro";
import BlogPostList from "@/components/blog/BlogPostList.astro";
import AIToggle from "@/components/blog/AIToggle.astro";
import {
  getAllPublishedBlogPostSummaries,
  collectTagCounts,
  filterPostsByTag,
  findTagBySlug,
} from "@/lib/blog";
import { SITE_URL } from "@/data/config";

export const prerender = false;

const { tag: tagSlug } = Astro.params;

if (!tagSlug || typeof tagSlug !== "string") {
  return Astro.redirect("/tags");
}

// AI filter param
const aiParam = Astro.url.searchParams.get("ai");
const showAI = aiParam === "on" ? true : aiParam === "off" ? false : false;

const allPosts = await getAllPublishedBlogPostSummaries();
const tagInfo = findTagBySlug(allPosts, tagSlug);
let posts = tagInfo ? filterPostsByTag(allPosts, tagSlug) : [];

// Count AI-generated posts in this tag
const aiPostCount = posts.filter((post) => post.aiGenerated).length;

// Filter AI-generated posts if showAI is false
if (!showAI) {
  posts = posts.filter((post) => !post.aiGenerated);
}

if (!tagInfo) {
  Astro.response.status = 404;
}

const articleLabel = posts.length === 1 ? "artikel" : "artikel";

const breadcrumbJsonLd = tagInfo
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Artikel", item: SITE_URL },
        { "@type": "ListItem", position: 2, name: "Tag", item: `${SITE_URL}/tags` },
        {
          "@type": "ListItem",
          position: 3,
          name: tagInfo.name,
          item: `${SITE_URL}/tags/${tagInfo.slug}`,
        },
      ],
    }
  : undefined;
---

<Layout
  title={tagInfo ? tagInfo.name : "Tag tidak ditemukan"}
  description={tagInfo ? `${posts.length} ${articleLabel} dengan tag "${tagInfo.name}".` : "Tag ini tidak ada."}
  noindex={!tagInfo}
  keywords={tagInfo ? [tagInfo.name, "blog", "artikel"] : undefined}
  jsonLd={breadcrumbJsonLd ? [breadcrumbJsonLd] : undefined}
>
  <div class="mx-auto w-full max-w-[42rem] pb-24">
    {tagInfo ? (
      <>
        <header class="mb-10">
          <nav class="mb-6" aria-label="Navigasi breadcrumb">
            <a
              href="/tags"
              class="inline-flex min-h-[44px] items-center gap-1.5 text-sm text-neutral-500 transition-colors hover:text-neutral-800 dark:text-neutral-500 dark:hover:text-neutral-300"
              data-astro-prefetch="hover"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              Tag
            </a>
          </nav>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
                {tagInfo.name}
              </h1>
              <p class="mt-2 text-sm tabular-nums text-neutral-500 dark:text-neutral-500">
                {posts.length} {articleLabel}
              </p>
            </div>
            <AIToggle showAI={showAI} hiddenCount={aiPostCount} />
          </div>
        </header>

        <div class="min-w-0">
          <BlogPostList posts={posts} />
        </div>
      </>
    ) : (
      <div class="py-16 text-center">
        <h1 class="mb-3 text-xl font-semibold text-neutral-900 dark:text-neutral-100">Tag tidak ditemukan</h1>
        <p class="mb-6 text-sm text-neutral-500 dark:text-neutral-400">Tidak ada artikel yang menggunakan tag ini.</p>
        <a
          href="/tags"
          class="text-sm font-medium text-neutral-700 underline-offset-2 hover:underline dark:text-neutral-300"
        >
          Lihat semua tag
        </a>
      </div>
    )}
  </div>
</Layout>
