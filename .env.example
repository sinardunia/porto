YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
YOUTUBE_CHANNEL_ID=YOUR_CHANNEL_ID

# Website configuration
SITE_URL=https://portokus.vercel.app/

# Decap CMS GitHub backend
# Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN

# Supabase project connection (not used with Decap CMS)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only secrets. Do not expose these to client-side code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
THOUGHTS_ADMIN_SECRET=YOUR_STRONG_RANDOM_ADMIN_SECRET

